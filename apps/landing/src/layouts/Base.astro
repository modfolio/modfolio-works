---
import Nav from "../components/Nav.astro";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "배움의 방식은 계속 바뀝니다. 본질은 지키되 방법에 안주하지 않는 교육 그룹.",
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, "https://works.modfolio.io");
---

<html lang="ko">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>{title}</title>
	<meta name="description" content={description} />
	<link rel="canonical" href={canonicalUrl.href} />
	<meta name="theme-color" content="#0E7C7B" />
	<meta name="color-scheme" content="light" />

	<!-- Open Graph -->
	<meta property="og:type" content="website" />
	<meta property="og:locale" content="ko_KR" />
	<meta property="og:site_name" content="Modfolio Works" />
	<meta property="og:title" content={title} />
	<meta property="og:description" content={description} />
	<meta property="og:url" content={canonicalUrl.href} />

	<!-- Fonts: Adobe Fonts (Master Kit) + Pretendard -->
	<link rel="preconnect" href="https://use.typekit.net" crossorigin />
	<link rel="stylesheet" href="https://use.typekit.net/fmh4fod.css" />
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />

	<!-- Cascade Layers -->
	<style is:inline>@layer reset, base, tokens, components, utilities;</style>

	<!-- Structured Data -->
	<script is:inline type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Organization",
		"name": "Modfolio Works",
		"description": "교육 그룹 — Naviaca, GistCore, Fortiscribe",
		"url": "https://works.modfolio.io",
		"parentOrganization": {
			"@type": "Organization",
			"name": "Modfolio",
			"url": "https://modfolio.io"
		}
	})} />
</head>
<body>
	<a href="#main" class="skip-to-content">본문으로 건너뛰기</a>

	<!-- SEO Navigation (screen reader only) -->
	<nav class="sr-only" aria-label="사이트 탐색">
		<ul>
			<li><a href="https://modfolio.io">Modfolio</a></li>
			<li><a href="https://naviaca.com">Naviaca</a></li>
			<li><a href="https://gistcore.com">GistCore</a></li>
			<li><a href="https://fortiscribe.com">Fortiscribe</a></li>
			<li><a href="https://connect.modfolio.io">Modfolio Connect</a></li>
		</ul>
	</nav>

	<Nav />
	<div class="nav-spacer" aria-hidden="true"></div>

	<slot />
</body>
</html>

<style>
	@layer components {
		.nav-spacer {
			height: var(--nav-h);
		}
	}
</style>
