---
import Base from "../layouts/Base.astro";
import Footer from "../components/landing/Footer.astro";

import "../styles/reset.css";
import "../styles/tokens.css";
import "../styles/global.css";

const values = [
	{
		title: "기술은 교육을 방해하지 않는다",
		desc: "좋은 교육 도구는 보이지 않습니다. 교사와 학생이 도구를 의식하지 않고 본질에 집중할 수 있도록 설계합니다.",
	},
	{
		title: "데이터는 학생의 것이다",
		desc: "학습 데이터의 소유권은 학생과 교육기관에 있습니다. 투명한 데이터 정책으로 신뢰를 쌓습니다.",
	},
	{
		title: "연결은 곧 가능성이다",
		desc: "학원 운영, 스피킹, 작문이 하나의 계정으로 연결될 때 교육의 전체 그림이 보입니다.",
	},
];

const hierarchy = [
	{ label: "Modfolio", desc: "생태계 모회사", accent: false },
	{ label: "Works", desc: "교육 그룹", accent: true },
	{ label: "Naviaca · GistCore · Fortiscribe", desc: "교육 앱", accent: false },
];
---

<Base title="소개 — Modfolio Works">
	<main id="main">
		<!-- Mission -->
		<section class="about-mission">
			<div class="about-mission__inner" data-reveal>
				<p class="about-mission__label">Our Mission</p>
				<h1 class="about-mission__title">
					교육의 미래를<br />연결합니다
				</h1>
			</div>
		</section>

		<!-- Description -->
		<section class="about-desc">
			<div class="about-desc__inner" data-reveal>
				<div class="about-desc__content">
					<h2 class="about-desc__heading">Works가 하는 일</h2>
					<p class="about-desc__text">
						Modfolio Works는 교육 현장의 문제를 기술로 해결하는 그룹입니다.
						학원 운영 플랫폼 Naviaca, AI 스피킹 연습 앱 GistCore, AI 작문 첨삭 앱
						Fortiscribe — 세 가지 앱이 하나의 계정 체계 아래 유기적으로 연결됩니다.
					</p>
					<p class="about-desc__text">
						학원 원장은 Naviaca에서 학생을 관리하면서 GistCore와 Fortiscribe의
						학습 데이터를 한눈에 확인합니다. 학생은 하나의 계정으로 스피킹 연습과
						작문 첨삭을 오가며 영어 실력을 쌓습니다. 따로 노는 도구들 사이의
						비효율을 없앱니다.
					</p>
				</div>
			</div>
		</section>

		<!-- Ecosystem Hierarchy -->
		<section class="about-eco">
			<div class="about-eco__inner" data-reveal>
				<h2 class="about-eco__heading">생태계 구조</h2>
				<div class="about-eco__tree">
					{hierarchy.map((item, i) => (
						<>
							{i > 0 && (
								<div class="about-eco__connector" aria-hidden="true">
									<svg width="2" height="40" viewBox="0 0 2 40">
										<line x1="1" y1="0" x2="1" y2="40" stroke="var(--color-border-default)" stroke-width="2" stroke-dasharray="4 4" />
									</svg>
								</div>
							)}
							<div class:list={[
								"about-eco__node",
								item.accent && "about-eco__node--accent",
							]}>
								<span class="about-eco__node-label">{item.label}</span>
								<span class="about-eco__node-desc">{item.desc}</span>
							</div>
						</>
					))}
				</div>
			</div>
		</section>

		<!-- Values -->
		<section class="about-values">
			<div class="about-values__inner">
				<h2 class="about-values__heading" data-reveal>우리가 믿는 것</h2>
				<div class="about-values__grid">
					{values.map((v, i) => (
						<article
							class="about-values__card"
							data-reveal
							data-reveal-delay={String(i * 120)}
						>
							<h3 class="about-values__card-title">{v.title}</h3>
							<p class="about-values__card-desc">{v.desc}</p>
						</article>
					))}
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Base>

<script>
	const reveals = document.querySelectorAll("[data-reveal]");

	if (reveals.length > 0) {
		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						const delay =
							(entry.target as HTMLElement).dataset.revealDelay || "0";
						(entry.target as HTMLElement).style.transitionDelay =
							`${delay}ms`;
						entry.target.classList.add("revealed");
						observer.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
		);

		for (const el of reveals) {
			el.classList.add("reveal-pending");
			observer.observe(el);
		}
	}
</script>

<style is:global>
	@layer utilities {
		.reveal-pending {
			opacity: 0;
			transform: translateY(16px);
		}

		.revealed {
			opacity: 1;
			transform: translateY(0);
			transition:
				opacity var(--dur-slow) var(--ease-out),
				transform var(--dur-slow) var(--ease-out);
		}

		@media (prefers-reduced-motion: reduce) {
			.reveal-pending {
				opacity: 1;
				transform: none;
			}
		}
	}
</style>

<style>
	@layer components {
		/* Mission */
		.about-mission {
			padding: var(--space-24) var(--mu-padding-x);
			background: linear-gradient(
				180deg,
				var(--color-surface-0) 0%,
				var(--p-teal-50) 100%
			);
			text-align: center;
			min-height: 70vh;
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.about-mission__inner {
			max-width: var(--mu-max-width);
			margin: 0 auto;
		}

		.about-mission__label {
			font-family: var(--font-ui);
			font-size: var(--font-size-caption);
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: var(--color-text-3);
			margin-bottom: var(--space-6);
		}

		.about-mission__title {
			font-family: var(--font-display);
			font-size: var(--font-size-display);
			font-weight: 700;
			line-height: 1.15;
			letter-spacing: -0.02em;
			background: linear-gradient(
				135deg,
				var(--p-teal-700),
				var(--p-teal-400)
			);
			background-clip: text;
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
		}

		/* Description */
		.about-desc {
			padding: clamp(4rem, 8vh, 8rem) var(--mu-padding-x);
			background: var(--color-surface-0);
		}

		.about-desc__inner {
			max-width: var(--mu-max-width);
			margin: 0 auto;
		}

		.about-desc__content {
			max-width: 680px;
		}

		.about-desc__heading {
			font-family: var(--font-display);
			font-size: var(--font-size-h2);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-6);
		}

		.about-desc__text {
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			color: var(--color-text-2);
			line-height: 1.8;
			margin-bottom: var(--space-4);
		}

		.about-desc__text:last-child {
			margin-bottom: 0;
		}

		/* Ecosystem */
		.about-eco {
			padding: clamp(4rem, 8vh, 8rem) var(--mu-padding-x);
			background: var(--color-surface-1);
		}

		.about-eco__inner {
			max-width: var(--mu-max-width);
			margin: 0 auto;
			text-align: center;
		}

		.about-eco__heading {
			font-family: var(--font-display);
			font-size: var(--font-size-h2);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-12);
		}

		.about-eco__tree {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0;
		}

		.about-eco__connector {
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.about-eco__node {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: var(--space-1);
			padding: var(--space-4) var(--space-8);
			background: var(--color-surface-card);
			border: 1px solid var(--color-border-subtle);
			border-radius: var(--radius-lg);
			box-shadow: var(--shadow-sm);
			min-width: 240px;
		}

		.about-eco__node--accent {
			border-color: var(--color-interactive-primary);
			box-shadow: var(--shadow-glow);
		}

		.about-eco__node-label {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 500;
			color: var(--color-text-1);
		}

		.about-eco__node--accent .about-eco__node-label {
			color: var(--color-interactive-primary);
		}

		.about-eco__node-desc {
			font-family: var(--font-ui);
			font-size: var(--font-size-caption);
			color: var(--color-text-3);
		}

		/* Values */
		.about-values {
			padding: clamp(4rem, 8vh, 8rem) var(--mu-padding-x);
			background: var(--color-surface-0);
		}

		.about-values__inner {
			max-width: var(--mu-max-width);
			margin: 0 auto;
		}

		.about-values__heading {
			font-family: var(--font-display);
			font-size: var(--font-size-h2);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-10);
		}

		.about-values__grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
			gap: var(--space-6);
		}

		.about-values__card {
			padding: var(--space-8);
			background: var(--color-surface-card);
			border: 1px solid var(--color-border-subtle);
			border-radius: var(--radius-lg);
			box-shadow: var(--shadow-sm);
		}

		.about-values__card-title {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-3);
		}

		.about-values__card-desc {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			color: var(--color-text-2);
			line-height: 1.7;
		}
	}
</style>
