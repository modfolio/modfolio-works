---
import Base from "../layouts/Base.astro";
import Hero from "../components/landing/Hero.astro";
import AppShowcase from "../components/landing/AppShowcase.astro";
import SocialProof from "../components/landing/SocialProof.astro";
import FAQ from "../components/landing/FAQ.astro";
import CTA from "../components/landing/CTA.astro";
import Header from "../components/portal/Header.astro";
import AppCard from "../components/portal/AppCard.astro";
import { apps } from "../lib/apps";

import "../styles/reset.css";
import "../styles/tokens.css";
import "../styles/global.css";

const user = Astro.locals.user;
const title = user
	? "포털 — Modfolio Works"
	: "Modfolio Works — 교육의 미래를 연결합니다";
---

<Base title={title}>
	{user ? (
		<>
			<Header userName={user.name} />
			<main id="main" class="portal-main">
				<h1 class="sr-only">Works 포털</h1>
				<div class="portal-grid">
					{apps.map((app) => (
						<AppCard app={app} />
					))}
				</div>
			</main>
		</>
	) : (
		<main id="main">
			<Hero />
			<AppShowcase apps={apps} />
			<SocialProof />
			<FAQ />
			<CTA />
		</main>
	)}
</Base>

<style>
	@layer components {
		.portal-main {
			max-width: 1080px;
			margin: 0 auto;
			padding: var(--space-8) var(--space-6);
		}

		.portal-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
			gap: var(--space-6);
		}
	}
</style>

<script>
	const reveals = document.querySelectorAll("[data-reveal]");

	if (reveals.length > 0) {
		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add("revealed");
						observer.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
		);

		for (const el of reveals) {
			el.classList.add("reveal-pending");
			observer.observe(el);
		}
	}
</script>

<style is:global>
	@layer utilities {
		.reveal-pending {
			opacity: 0;
			transform: translateY(12px);
		}

		.revealed {
			opacity: 1;
			transform: translateY(0);
			transition:
				opacity var(--dur-slow) var(--ease-out),
				transform var(--dur-slow) var(--ease-out);
		}

		@media (prefers-reduced-motion: reduce) {
			.reveal-pending {
				opacity: 1;
				transform: none;
			}
		}
	}
</style>
