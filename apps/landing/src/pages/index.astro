---
import Base from "../layouts/Base.astro";
import Hero from "../components/landing/Hero.astro";
import Philosophy from "../components/landing/Philosophy.astro";
import AppShowcase from "../components/landing/AppShowcase.astro";
import HowItWorks from "../components/landing/HowItWorks.astro";
import FAQ from "../components/landing/FAQ.astro";
import CTA from "../components/landing/CTA.astro";
import Footer from "../components/landing/Footer.astro";
import { apps } from "../lib/apps";

import "../styles/reset.css";
import "../styles/tokens.css";
import "../styles/global.css";
---

<Base title="Modfolio Works — Where Potential Unfolds">
	<main id="main">
		<Hero />
		<Philosophy />
		<AppShowcase apps={apps} />
		<HowItWorks />
		<FAQ />
		<CTA />
	</main>
	<Footer />
</Base>

<script>
	import { initReveal } from "../lib/reveal";
	initReveal();
</script>

<style is:global>
	@layer utilities {
		.reveal-pending {
			opacity: 0;
			transform: translateY(16px);
		}

		.revealed {
			opacity: 1;
			transform: translateY(0);
			transition:
				opacity var(--dur-slow) var(--ease-out),
				transform var(--dur-slow) var(--ease-out);
		}

		@media (prefers-reduced-motion: reduce) {
			.reveal-pending {
				opacity: 1;
				transform: none;
			}
		}
	}
</style>
