---
import Base from "../layouts/Base.astro";
import Footer from "../components/landing/Footer.astro";
import { apps } from "../lib/apps";

import "../styles/reset.css";
import "../styles/tokens.css";
import "../styles/global.css";
---

<Base title="Apps — Modfolio Works" description="학원 운영, AI 스피킹, 작문 첨삭. 교육의 각 단계를 맡는 세 가지 앱.">
	<main id="main">
		<section class="apps-hero" aria-label="교육 앱">
			<div class="apps-hero__inner" data-reveal>
				<p class="apps-hero__eyebrow">Apps</p>
				<h1 class="apps-hero__title">각자의 영역에서, 정확하게.</h1>
				<p class="apps-hero__sub">
					학원 운영, 스피킹 연습, 작문 첨삭.<br class="hide-mobile" />
					세 가지 앱이 교육의 각 단계를 맡습니다.
				</p>
			</div>
		</section>

		<section class="apps-grid-section" aria-label="앱 목록">
			<div class="apps-grid">
				{apps.map((app, i) => (
					<a
						href={`/apps/${app.id}`}
						class="apps-card"
						data-reveal
						data-reveal-delay={String(i * 120)}
					>
						<div class="apps-card__body">
							<div class="apps-card__header">
								<h2 class="apps-card__name">{app.name}</h2>
								<span
									class:list={[
										"apps-card__status",
										app.status === "active"
											? "apps-card__status--active"
											: "apps-card__status--landing",
									]}
								>
									{app.status === "active" ? "운영 중" : "출시 준비 중"}
								</span>
							</div>
							<p class="apps-card__tagline">{app.tagline}</p>
							<p class="apps-card__desc">{app.shortDescription}</p>
							<div class="apps-card__footer">
								<span class="apps-card__domain">{app.domain}</span>
								<span class="apps-card__link">자세히 보기 →</span>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
	<Footer />
</Base>

<script>
	import { initReveal } from "../lib/reveal";
	initReveal();
</script>

<style>
	@layer components {
		.apps-hero {
			min-height: 40vh;
			display: flex;
			align-items: center;
			justify-content: center;
			background: var(--color-surface-0);
			padding: var(--space-24) var(--mu-padding-x) var(--space-16);
			text-align: center;
		}

		.apps-hero__inner {
			max-width: var(--mu-max-width);
		}

		.apps-hero__eyebrow {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--color-text-3);
			margin-bottom: var(--space-4);
		}

		.apps-hero__title {
			font-family: var(--font-display);
			font-size: var(--font-size-h1);
			font-weight: 700;
			color: var(--color-text-1);
			line-height: 1.2;
			margin-bottom: var(--space-4);
		}

		.apps-hero__sub {
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			color: var(--color-text-2);
			line-height: 1.6;
			max-width: 50ch;
			margin: 0 auto;
		}

		.hide-mobile {
			display: none;
		}

		@media (min-width: 640px) {
			.hide-mobile {
				display: inline;
			}
		}

		/* ── Card Grid ── */
		.apps-grid-section {
			padding: var(--space-16) var(--mu-padding-x) var(--space-24);
			background: var(--color-surface-1);
		}

		.apps-grid {
			max-width: 1080px;
			margin: 0 auto;
			display: grid;
			grid-template-columns: 1fr;
			gap: var(--space-6);
		}

		@media (min-width: 768px) {
			.apps-grid {
				grid-template-columns: repeat(3, 1fr);
			}
		}

		.apps-card {
			display: flex;
			flex-direction: column;
			background: var(--color-surface-card);
			border-radius: var(--radius-lg);
			overflow: hidden;
			box-shadow: var(--shadow-sm);
			transition:
				transform var(--dur-fast) var(--ease-out),
				box-shadow var(--dur-fast) var(--ease-out);
		}

		.apps-card:hover {
			transform: translateY(-4px);
			box-shadow: var(--shadow-md);
		}

		.apps-card__body {
			padding: var(--space-6);
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		.apps-card__header {
			display: flex;
			align-items: center;
			justify-content: space-between;
			margin-bottom: var(--space-2);
		}

		.apps-card__name {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 400;
			color: var(--color-text-1);
		}

		.apps-card__status {
			font-size: var(--font-size-caption);
			font-family: var(--font-ui);
			letter-spacing: 0.02em;
			padding: var(--space-1) var(--space-3);
			border-radius: var(--radius-full);
		}

		.apps-card__status--active {
			background: var(--color-status-active-bg);
			color: var(--color-success);
		}

		.apps-card__status--landing {
			background: var(--color-status-pending-bg);
			color: var(--color-accent-fortiscribe);
		}

		.apps-card__tagline {
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-3);
		}

		.apps-card__desc {
			font-size: var(--font-size-small);
			color: var(--color-text-2);
			line-height: 1.65;
			margin-bottom: var(--space-6);
			flex: 1;
		}

		.apps-card__footer {
			display: flex;
			align-items: center;
			justify-content: space-between;
		}

		.apps-card__domain {
			font-size: var(--font-size-caption);
			color: var(--color-text-3);
		}

		.apps-card__link {
			font-size: var(--font-size-caption);
			color: var(--color-text-3);
			transition: color var(--dur-fast) var(--ease-out);
		}

		.apps-card:hover .apps-card__link {
			color: var(--color-interactive-primary);
		}
	}
</style>
