---
---

<section class="hero" aria-label="Modfolio Works 소개">
	<div class="hero-mesh" aria-hidden="true"></div>
	<div class="hero-grain" aria-hidden="true"></div>

	<div class="hero-content">
		<div class="hero-text">
			<p class="hero-eyebrow">Modfolio Works</p>
			<h1 class="hero-title">배움의 방식이<br />바뀌고 있습니다.</h1>
			<p class="hero-sub">우리는 그 다음을 준비합니다.</p>
			<div class="hero-actions">
				<a href="https://edu.modfolio.io" class="hero-btn hero-btn--primary">
					Get Started
				</a>
				<a href="/apps" class="hero-btn hero-btn--secondary">
					앱 둘러보기
				</a>
			</div>
		</div>

		<div class="hero-visual" data-parallax aria-hidden="true">
			<div class="hero-visual__frame">
				<img
					src="/images/hero/visual.svg"
					alt="교육 환경"
					class="hero-visual__img"
					loading="eager"
					decoding="async"
				/>
				<div class="hero-visual__scrim"></div>
			</div>
		</div>
	</div>

	<div class="hero-scroll-hint" aria-hidden="true">
		<svg width="24" height="24" viewBox="0 0 24 24" fill="none">
			<path d="M7 10l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
		</svg>
	</div>
</section>

<style>
	@layer components {
		.hero {
			position: relative;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			min-height: calc(100dvh - var(--nav-h));
			padding: var(--space-8) var(--mu-padding-x);
			overflow: hidden;
		}

		/* ── Gradient Mesh Background ── */
		.hero-mesh {
			position: absolute;
			inset: 0;
			pointer-events: none;
			background:
				radial-gradient(ellipse at 20% 50%, var(--p-teal-100) 0%, transparent 50%),
				radial-gradient(ellipse at 80% 20%, oklch(0.92 0.06 155) 0%, transparent 40%),
				radial-gradient(ellipse at 50% 80%, oklch(0.95 0.04 65) 0%, transparent 45%),
				var(--color-surface-0);
			background-size: 200% 200%;
			animation: mesh-float 20s var(--ease-float) infinite alternate;
		}

		@keyframes mesh-float {
			0% {
				background-position: 0% 0%, 100% 0%, 50% 100%;
			}
			33% {
				background-position: 10% 20%, 90% 10%, 40% 80%;
			}
			66% {
				background-position: 5% 10%, 95% 15%, 55% 90%;
			}
			100% {
				background-position: 15% 5%, 85% 20%, 45% 85%;
			}
		}

		/* ── Grain Overlay ── */
		.hero-grain {
			position: absolute;
			inset: 0;
			opacity: 0.015;
			pointer-events: none;
			background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
			background-repeat: repeat;
			background-size: 256px 256px;
		}

		/* ── Content ── */
		.hero-content {
			position: relative;
			z-index: 1;
			width: 100%;
			max-width: var(--mu-max-width);
			display: grid;
			grid-template-columns: 1fr;
			align-items: center;
			gap: var(--space-8);
			text-align: center;
			transform: translateY(calc(var(--scroll-y, 0) * -0.2px));
			will-change: transform;
		}

		/* ── Text column ── */
		.hero-text {
			text-align: center;
		}

		/* ── Visual column ── */
		.hero-visual {
			max-width: 320px;
			margin: 0 auto;
		}

		.hero-visual__frame {
			position: relative;
			background: var(--color-surface-raised);
			padding: var(--space-3);
			border-radius: var(--radius-xl);
			box-shadow: var(--shadow-xl);
			transform: rotate(3deg);
			transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1);
			overflow: hidden;
		}

		.hero-visual:hover .hero-visual__frame {
			transform: rotate(0deg);
		}

		.hero-visual__img {
			width: 100%;
			height: auto;
			border-radius: var(--radius-lg);
			aspect-ratio: 1;
			object-fit: cover;
			background: var(--p-teal-100);
			display: block;
			transition: transform 1s cubic-bezier(0.23, 1, 0.32, 1);
		}

		.hero-visual:hover .hero-visual__img {
			transform: scale(0.98);
		}

		.hero-visual__scrim {
			position: absolute;
			bottom: var(--space-3);
			left: var(--space-3);
			right: var(--space-3);
			height: 30%;
			background: linear-gradient(to top, oklch(0.15 0.02 175 / 0.2), transparent);
			border-radius: 0 0 var(--radius-lg) var(--radius-lg);
			pointer-events: none;
		}

		/* ── Title ── */
		.hero-title {
			font-family: var(--font-display);
			font-size: var(--font-size-display);
			font-weight: 700;
			line-height: 1.15;
			letter-spacing: -0.02em;
			background: linear-gradient(
				135deg,
				var(--p-teal-700),
				var(--p-teal-400)
			);
			background-clip: text;
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			text-shadow: none;
			margin-bottom: var(--space-6);
		}

		/* ── Eyebrow ── */
		.hero-eyebrow {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--color-text-3);
			margin-bottom: var(--space-4);
		}

		/* ── Sub ── */
		.hero-sub {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-8);
		}

		/* ── CTA Buttons ── */
		.hero-actions {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: var(--space-4);
			flex-wrap: wrap;
		}

		.hero-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: var(--space-3) var(--space-6);
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			font-weight: 600;
			border-radius: var(--radius-md);
			transition:
				transform var(--dur-fast) var(--ease-out),
				box-shadow var(--dur-fast) var(--ease-out),
				background var(--dur-fast) var(--ease-out),
				color var(--dur-fast) var(--ease-out);
		}

		.hero-btn:active {
			transform: scale(0.98);
		}

		.hero-btn--primary {
			background: linear-gradient(135deg, var(--color-interactive-primary), var(--p-teal-400));
			color: var(--color-surface-0);
			animation: pulse-glow 3s var(--ease-float) infinite;
		}

		.hero-btn--primary:hover {
			background: var(--color-interactive-hover);
			transform: translateY(-2px);
			box-shadow: var(--shadow-glow);
			animation: none;
		}

		.hero-btn--secondary {
			background: var(--color-interactive-muted);
			color: var(--color-interactive-primary);
			border: none;
		}

		.hero-btn--secondary:hover {
			background: var(--color-interactive-muted);
			transform: translateY(-2px);
		}

		@keyframes pulse-glow {
			0%, 100% {
				box-shadow: 0 0 0 0 transparent;
			}
			50% {
				box-shadow: var(--shadow-glow);
			}
		}

		/* ── Desktop: 2-column layout ── */
		@media (min-width: 768px) {
			.hero-content {
				grid-template-columns: 1fr 1fr;
				text-align: left;
			}

			.hero-text {
				text-align: left;
			}

			.hero-actions {
				justify-content: flex-start;
			}

			.hero-visual {
				max-width: 100%;
				margin: 0;
			}
		}

		/* ── Scroll Hint ── */
		.hero-scroll-hint {
			position: absolute;
			bottom: var(--space-8);
			color: var(--p-teal-400);
			animation: hero-bounce 2s var(--ease-float) infinite;
		}

		@keyframes hero-bounce {
			0%,
			100% {
				transform: translateY(0);
			}
			50% {
				transform: translateY(8px);
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.hero-mesh {
				animation: none;
			}
			.hero-btn--primary {
				animation: none;
			}
			.hero-scroll-hint {
				animation: none;
			}
			.hero-visual__frame {
				transform: none;
			}
			.hero-visual:hover .hero-visual__frame {
				transform: none;
			}
			.hero-visual__img {
				transition: none;
			}
			.hero-visual:hover .hero-visual__img {
				transform: none;
			}
		}
	}
</style>
