---
import type { WorksApp } from "../../lib/apps";

interface Props {
	apps: WorksApp[];
}

const { apps } = Astro.props;
---

<section class="app-highlight" aria-label="교육 앱 소개">
	<div class="app-highlight__inner">
		<h2 class="app-highlight__heading" data-reveal>교육 앱</h2>
		<div class="app-highlight__grid">
			{apps.map((app, i) => (
				<article
					class="app-card"
					data-reveal
					data-reveal-delay={String(i * 120)}
				>
					<div class="app-card__header">
						<div
							class="app-card__icon"
							style={`background: ${app.accentVar}`}
						>
							<span class="app-card__initial">
								{app.name.charAt(0)}
							</span>
						</div>
						<h3 class="app-card__name">{app.name}</h3>
					</div>
					<div class="app-card__body">
						<p class="app-card__tagline">{app.tagline}</p>
						<p class="app-card__desc">{app.description}</p>
					</div>
					<div class="app-card__footer">
						<a
							href={`/apps#${app.id}`}
							class="app-card__link"
						>
							자세히 보기 &rarr;
						</a>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	@layer components {
		.app-highlight {
			background: var(--color-surface-1);
			padding: var(--space-24) var(--mu-padding-x);
		}

		.app-highlight__inner {
			max-width: var(--mu-max-width);
			margin: 0 auto;
		}

		.app-highlight__heading {
			font-family: var(--font-display);
			font-size: var(--font-size-h2);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-10);
		}

		.app-highlight__grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
			gap: var(--space-6);
		}

		/* Card */
		.app-card {
			display: flex;
			flex-direction: column;
			min-height: 280px;
			padding: var(--space-8);
			background: var(--color-surface-card);
			border: 1px solid var(--color-border-subtle);
			border-radius: var(--radius-lg);
			box-shadow: var(--shadow-sm);
			transition:
				transform var(--dur-base) var(--ease-out),
				box-shadow var(--dur-base) var(--ease-out);
		}

		.app-card:hover {
			transform: translateY(-4px);
			box-shadow: var(--shadow-md);
		}

		.app-card__header {
			display: flex;
			align-items: center;
			gap: var(--space-3);
			margin-bottom: var(--space-6);
		}

		.app-card__icon {
			display: grid;
			place-items: center;
			width: 48px;
			height: 48px;
			border-radius: var(--radius-full);
			flex-shrink: 0;
		}

		.app-card__initial {
			font-family: var(--font-display);
			font-size: var(--font-size-body);
			font-weight: 700;
			color: var(--color-surface-0);
			line-height: 1;
		}

		.app-card__name {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 400;
			color: var(--color-text-1);
		}

		.app-card__body {
			flex: 1;
		}

		.app-card__tagline {
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-3);
		}

		.app-card__desc {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			color: var(--color-text-2);
			line-height: 1.7;
		}

		.app-card__footer {
			margin-top: auto;
			padding-top: var(--space-6);
		}

		.app-card__link {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			color: var(--color-text-3);
			transition: color var(--dur-fast) var(--ease-out);
		}

		.app-card__link:hover {
			color: var(--color-interactive-primary);
		}
	}
</style>
