---
const educationLinks = [
	{ name: "Naviaca", url: "https://naviaca.com" },
	{ name: "GistCore", url: "https://gistcore.com" },
	{ name: "Fortiscribe", url: "https://fortiscribe.com" },
];

const platformLinks = [
	{ name: "Connect", url: "https://connect.modfolio.io" },
	{ name: "Pay", url: "https://pay.modfolio.io" },
	{ name: "Docs", url: "https://docs.modfolio.io" },
];

const ecosystemLinks = [
	{ name: "Works", url: "https://works.modfolio.io", isSelf: true },
	{ name: "LS", url: "https://ls.modfolio.io", isSelf: false },
	{ name: "Axiom", url: "https://axiom.modfolio.io", isSelf: false },
	{ name: "Studio", url: "https://studio.modfolio.io", isSelf: false },
];

const siteLinks = [
	{ name: "앱 소개", url: "/apps" },
	{ name: "소개", url: "/about" },
	{ name: "FAQ", url: "/faq" },
];
---

<footer class="footer">
	<div class="footer__top">
		<div class="footer__grid">
			<!-- Brand Column -->
			<div class="footer__brand">
				<h3 class="footer__logo">Modfolio Works</h3>
				<p class="footer__tagline">교육의 미래를 연결합니다</p>
				<nav class="footer__site-links" aria-label="사이트 페이지">
					{siteLinks.map((link) => (
						<a href={link.url} class="footer__link">{link.name}</a>
					))}
				</nav>
				<div class="footer__sns" aria-label="소셜 미디어">
					<!-- Instagram -->
					<a
						href="https://instagram.com/modfolio.io"
						class="footer__sns-link"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="Instagram"
					>
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5" />
							<circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5" />
							<circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" />
						</svg>
					</a>
					<!-- LinkedIn -->
					<a
						href="https://linkedin.com/company/modfolio"
						class="footer__sns-link"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn"
					>
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							<rect x="2" y="9" width="4" height="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							<circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="1.5" />
						</svg>
					</a>
					<!-- YouTube -->
					<a
						href="https://youtube.com/@modfolio"
						class="footer__sns-link"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="YouTube"
					>
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29.94 29.94 0 0 0 1 12a29.94 29.94 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.94 2C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2A29.94 29.94 0 0 0 23 12a29.94 29.94 0 0 0-.46-5.58z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
							<path d="M9.75 15.02l5.25-3.02-5.25-3.02v6.04z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
						</svg>
					</a>
				</div>
			</div>

			<!-- Education Column -->
			<nav class="footer__col" aria-label="교육 앱">
				<h4 class="footer__col-heading">Education</h4>
				<ul class="footer__col-list">
					{educationLinks.map((link) => (
						<li>
							<a href={link.url} class="footer__link" target="_blank" rel="noopener noreferrer">
								{link.name}
							</a>
						</li>
					))}
				</ul>
			</nav>

			<!-- Platform Column -->
			<nav class="footer__col" aria-label="플랫폼">
				<h4 class="footer__col-heading">Platform</h4>
				<ul class="footer__col-list">
					{platformLinks.map((link) => (
						<li>
							<a href={link.url} class="footer__link" target="_blank" rel="noopener noreferrer">
								{link.name}
							</a>
						</li>
					))}
				</ul>
			</nav>

			<!-- Ecosystem Column -->
			<nav class="footer__col" aria-label="생태계">
				<h4 class="footer__col-heading">Ecosystem</h4>
				<ul class="footer__col-list">
					{ecosystemLinks.map((link) => (
						<li>
							<a
								href={link.url}
								class:list={["footer__link", link.isSelf && "footer__link--self"]}
								{...(link.isSelf ? {} : { target: "_blank", rel: "noopener noreferrer" })}
							>
								{link.name}
							</a>
						</li>
					))}
				</ul>
			</nav>
		</div>
	</div>

	<div class="footer__bottom">
		<div class="footer__bottom-inner">
			<p class="footer__legal">
				모드폴리오 &middot; 대표 김동헌 &middot; 사업자등록번호 104-95-65636 &middot;
				통신판매업 제2025-수원팔달-0953호 &middot; 출판사 제2024-000037호 &middot;
				경기도 수원시 팔달구 효원로 278, 6층 602호 &middot;
				contact@modfolio.io
			</p>
			<p class="footer__copyright">&copy; 2026 Modfolio. All rights reserved.</p>
		</div>
	</div>
</footer>

<style>
	@layer components {
		.footer {
			background: var(--color-surface-1);
			border-top: 1px solid var(--color-border-subtle);
		}

		/* Top Section */
		.footer__top {
			max-width: var(--mu-max-width);
			margin: 0 auto;
			padding: var(--space-16) var(--mu-padding-x);
		}

		.footer__grid {
			display: grid;
			grid-template-columns: 2fr 1fr 1fr 1fr;
			gap: var(--space-8);
		}

		@media (max-width: 960px) {
			.footer__grid {
				grid-template-columns: 1fr 1fr;
				gap: var(--space-10);
			}
		}

		@media (max-width: 480px) {
			.footer__grid {
				grid-template-columns: 1fr;
				gap: var(--space-8);
			}
		}

		/* Brand */
		.footer__brand {
			display: flex;
			flex-direction: column;
			gap: var(--space-3);
		}

		.footer__logo {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 500;
			color: var(--color-text-1);
		}

		.footer__tagline {
			font-family: var(--font-ui);
			font-size: var(--font-size-caption);
			color: var(--color-text-3);
		}

		.footer__site-links {
			display: flex;
			gap: var(--space-4);
			margin-top: var(--space-2);
		}

		/* SNS Icons */
		.footer__sns {
			display: flex;
			gap: var(--space-4);
			margin-top: var(--space-1);
		}

		.footer__sns-link {
			display: flex;
			align-items: center;
			justify-content: center;
			color: var(--color-text-3);
			transition: color var(--dur-fast) var(--ease-out);
		}

		.footer__sns-link:hover {
			color: var(--color-text-1);
		}

		/* Columns */
		.footer__col-heading {
			font-family: var(--font-ui);
			font-size: var(--font-size-caption);
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--color-text-3);
			margin-bottom: var(--space-4);
		}

		.footer__col-list {
			display: flex;
			flex-direction: column;
			gap: var(--space-3);
		}

		/* Links */
		.footer__link {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			color: var(--color-text-2);
			transition: color var(--dur-fast) var(--ease-out);
		}

		.footer__link:hover {
			color: var(--color-interactive-primary);
		}

		.footer__link--self {
			font-weight: 600;
			color: var(--color-interactive-primary);
		}

		/* Bottom Bar */
		.footer__bottom {
			border-top: 1px solid var(--color-border-subtle);
		}

		.footer__bottom-inner {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: var(--space-4);
			max-width: var(--mu-max-width);
			margin: 0 auto;
			padding: var(--space-4) var(--mu-padding-x);
		}

		@media (max-width: 768px) {
			.footer__bottom-inner {
				flex-direction: column;
				align-items: flex-start;
			}
		}

		.footer__legal {
			font-family: var(--font-ui);
			font-size: var(--font-size-caption);
			color: var(--color-text-3);
			line-height: 1.6;
		}

		.footer__copyright {
			font-family: var(--font-ui);
			font-size: var(--font-size-caption);
			color: var(--color-text-3);
			white-space: nowrap;
		}
	}
</style>
