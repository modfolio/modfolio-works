---
import type { WorksApp } from "../../lib/apps";

interface Props {
	apps: WorksApp[];
}

const { apps } = Astro.props;
---

<section class="showcase" id="apps" aria-label="교육 앱">
	<div class="showcase-inner">
		<p class="showcase-eyebrow">Apps</p>
		<h2 class="showcase-heading" data-reveal>지금, 여기서부터.</h2>
		<div class="showcase-grid">
			{apps.map((app, i) => (
				<a
					href={`/apps/${app.id}`}
					class:list={[
						"showcase-card",
						{ "showcase-card--offset": i === 1 },
					]}
					data-reveal
					data-reveal-delay={String(i * 120)}
				>
					<div class="showcase-card__image">
						<img
							src={app.cardImage}
							alt={`${app.name} 미리보기`}
							class="showcase-card__img"
							loading="lazy"
							decoding="async"
						/>
					</div>
					<div class="showcase-card__body">
						<h3 class="showcase-card__name">{app.name}</h3>
						<p class="showcase-card__tagline">{app.tagline}</p>
						<p class="showcase-card__desc">{app.shortDescription}</p>
						<p class="showcase-card__outcome">{app.outcome}</p>
						<div class="showcase-card__footer">
							<span class="showcase-card__cta">자세히 보기 · {app.domain}</span>
							<span
								class:list={[
									"showcase-card__status",
									app.status === "active"
										? "showcase-card__status--active"
										: "showcase-card__status--landing",
								]}
							>
								{app.status === "active" ? "운영 중" : "출시 준비 중"}
							</span>
						</div>
					</div>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	@layer components {
		.showcase {
			padding: var(--space-24) var(--mu-padding-x);
			background: var(--color-surface-1);
		}

		.showcase-inner {
			max-width: 1080px;
			margin: 0 auto;
		}

		.showcase-eyebrow {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--color-text-3);
			text-align: center;
			margin-bottom: var(--space-4);
		}

		.showcase-heading {
			font-family: var(--font-display);
			font-size: var(--font-size-h2);
			font-weight: 500;
			text-align: center;
			margin-bottom: var(--space-16);
			color: var(--color-text-1);
		}

		.showcase-grid {
			display: grid;
			grid-template-columns: 1fr;
			gap: var(--space-6);
		}

		@media (min-width: 768px) {
			.showcase-grid {
				grid-template-columns: repeat(3, 1fr);
				gap: var(--space-6);
				align-items: start;
			}

			.showcase-card--offset {
				transform: translateY(var(--space-8));
			}
		}

		.showcase-card {
			position: relative;
			display: flex;
			flex-direction: column;
			background: var(--color-surface-card);
			border-radius: var(--radius-lg);
			overflow: hidden;
			box-shadow: var(--shadow-sm);
			transition:
				transform var(--dur-fast) var(--ease-snap),
				box-shadow var(--dur-fast) var(--ease-out);
		}

		.showcase-card:hover {
			transform: translateY(-4px);
			box-shadow: var(--shadow-md);
		}

		@media (min-width: 768px) {
			.showcase-card--offset:hover {
				transform: translateY(calc(var(--space-8) - 4px));
			}
		}

		.showcase-card__image {
			position: relative;
			aspect-ratio: 16 / 9;
			overflow: hidden;
			background: var(--color-surface-raised);
		}

		.showcase-card__img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			transition: transform var(--dur-slow) var(--ease-out);
		}

		.showcase-card:hover .showcase-card__img {
			transform: scale(1.03);
		}

		.showcase-card__body {
			padding: var(--space-6);
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		.showcase-card__name {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 400;
			margin-bottom: var(--space-2);
			color: var(--color-text-1);
		}

		.showcase-card__tagline {
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-3);
		}

		.showcase-card__desc {
			font-size: var(--font-size-small);
			color: var(--color-text-2);
			line-height: 1.65;
			margin-bottom: var(--space-4);
		}

		.showcase-card__outcome {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 600;
			color: var(--color-interactive-primary);
			margin-bottom: var(--space-6);
			flex: 1;
		}

		.showcase-card__footer {
			display: flex;
			align-items: center;
			justify-content: space-between;
		}

		.showcase-card__cta {
			font-size: var(--font-size-caption);
			color: var(--color-text-3);
			font-family: var(--font-ui);
			transition: color var(--dur-fast) var(--ease-out);
		}

		.showcase-card:hover .showcase-card__cta {
			color: var(--color-interactive-primary);
		}

		.showcase-card__status {
			font-size: var(--font-size-caption);
			font-family: var(--font-ui);
			letter-spacing: 0.02em;
			padding: var(--space-1) var(--space-3);
			border-radius: var(--radius-full);
		}

		.showcase-card__status--active {
			background: var(--color-status-active-bg);
			color: var(--color-success);
		}

		.showcase-card__status--landing {
			background: var(--color-status-pending-bg);
			color: var(--color-accent-fortiscribe);
		}
	}
</style>
