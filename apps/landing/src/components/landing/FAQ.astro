---
const faqs = [
	{
		q: "각 앱은 따로 가입해야 하나요?",
		a: "아닙니다. Modfolio Connect 계정 하나로 Works의 모든 앱을 이용할 수 있습니다.",
	},
	{
		q: "어떤 학원에 적합한가요?",
		a: "규모에 관계없이 모든 학원에 적합합니다. 특히 여러 반을 운영하는 어학원이나 보습학원에서 효과적입니다.",
	},
	{
		q: "GistCore의 AI 튜터는 어떻게 작동하나요?",
		a: "OPIc 실전 시나리오를 기반으로 AI와 대화 연습을 합니다. 발화 분석, 문법 교정, 표현 추천 등 즉각적인 피드백을 제공합니다.",
	},
	{
		q: "Fortiscribe는 어떤 언어를 지원하나요?",
		a: "영어와 한국어 작문을 지원합니다. AI가 문법, 구조, 논리를 다각도로 첨삭합니다.",
	},
	{
		q: "데이터는 안전한가요?",
		a: "모든 데이터는 암호화되어 전송 및 저장됩니다. 데이터 소유권은 사용자에게 있으며 언제든 내보낼 수 있습니다.",
	},
	{
		q: "학원이나 기관에서 도입하려면 어떻게 하나요?",
		a: "계정을 생성한 후 각 앱에 로그인하면 바로 사용할 수 있습니다. 단체 도입이나 협업이 필요한 경우 contact@modfolio.io로 연락해주세요.",
	},
];
---

<section class="faq" aria-label="자주 묻는 질문" data-reveal>
	<h2 class="faq-heading">자주 묻는 질문</h2>
	<div class="faq-list">
		{faqs.map((item) => (
			<details class="faq-item">
				<summary class="faq-question">
					<span>{item.q}</span>
					<svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
						<path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</summary>
				<div class="faq-answer">
					<p>{item.a}</p>
				</div>
			</details>
		))}
	</div>
</section>

<style>
	@layer components {
		.faq {
			padding: var(--space-24) var(--mu-padding-x);
			max-width: 720px;
			margin: 0 auto;
		}

		.faq-heading {
			font-family: var(--font-display);
			font-size: var(--font-size-h2);
			font-weight: 500;
			text-align: center;
			margin-bottom: var(--space-12);
			color: var(--color-text-1);
		}

		.faq-list {
			display: flex;
			flex-direction: column;
		}

		.faq-item {
			border-bottom: 1px solid var(--color-border-subtle);
			transition: border-color var(--dur-fast) var(--ease-out);
		}

		.faq-item[open] {
			background: var(--p-teal-50);
			border-radius: var(--radius-sm);
		}

		.faq-question {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: var(--space-4);
			padding: var(--space-4) var(--space-6);
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			font-weight: 500;
			color: var(--color-text-1);
			cursor: pointer;
			user-select: none;
			list-style: none;
			transition: background var(--dur-fast) var(--ease-out);
		}

		.faq-question::-webkit-details-marker {
			display: none;
		}

		.faq-question:hover {
			background: var(--p-teal-50);
		}

		.faq-chevron {
			flex-shrink: 0;
			color: var(--color-text-3);
			transition: transform var(--dur-base) var(--ease-snap);
		}

		.faq-item[open] .faq-chevron {
			transform: rotate(180deg);
		}

		.faq-answer {
			display: grid;
			grid-template-rows: 0fr;
			transition: grid-template-rows var(--dur-base) var(--ease-out);
		}

		.faq-item[open] .faq-answer {
			grid-template-rows: 1fr;
		}

		.faq-answer > p {
			overflow: hidden;
			padding: 0 var(--space-6) var(--space-4);
			font-size: var(--font-size-small);
			color: var(--color-text-2);
			line-height: 1.7;
			max-width: 60ch;
		}
	}
</style>
