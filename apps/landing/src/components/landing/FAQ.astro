---
const faqs = [
	{
		q: "Works는 무료인가요?",
		a: "Works 포털은 무료입니다. 개별 앱(Naviaca, GistCore, Fortiscribe)의 요금은 각 앱에서 확인하세요.",
	},
	{
		q: "다른 Modfolio 앱과 어떤 관계인가요?",
		a: "Modfolio Works는 교육 전문 자회사 그룹입니다. Modfolio Connect 계정 하나로 모든 교육 앱을 이용할 수 있습니다.",
	},
	{
		q: "데이터는 안전한가요?",
		a: "모든 앱은 Cloudflare Edge 네트워크에서 운영되며, Modfolio Connect SSO가 OIDC 표준으로 인증을 관리합니다.",
	},
	{
		q: "어떻게 시작하나요?",
		a: "상단의 '시작하기' 버튼을 누르면 Modfolio Connect 계정으로 1분 안에 로그인할 수 있습니다. 별도 가입 없이 기존 Modfolio 계정을 사용합니다.",
	},
];
---

<section class="faq" aria-label="자주 묻는 질문" data-reveal>
	<h2 class="faq-heading">자주 묻는 질문</h2>
	<div class="faq-list">
		{faqs.map((item) => (
			<details class="faq-item">
				<summary class="faq-question">
					<span>{item.q}</span>
					<svg class="faq-chevron" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
						<path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</summary>
				<div class="faq-answer">
					<p>{item.a}</p>
				</div>
			</details>
		))}
	</div>
</section>

<style>
	@layer components {
		.faq {
			padding: var(--space-24) var(--space-6);
			max-width: 720px;
			margin: 0 auto;
		}

		.faq-heading {
			font-family: var(--font-display);
			font-size: var(--font-size-h2);
			font-weight: 500;
			text-align: center;
			margin-bottom: var(--space-12);
			color: var(--color-text-1);
		}

		.faq-list {
			display: flex;
			flex-direction: column;
		}

		.faq-item {
			border-bottom: 1px solid var(--color-border-subtle);
			transition: border-color var(--dur-fast) var(--ease-out);
		}

		.faq-item[open] {
			border-left: 2px solid var(--color-interactive-primary);
			padding-left: var(--space-4);
		}

		.faq-question {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: var(--space-4);
			padding: var(--space-4) var(--space-6);
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			font-weight: 500;
			color: var(--color-text-1);
			cursor: pointer;
			user-select: none;
			list-style: none;
			transition: background var(--dur-fast) var(--ease-out);
		}

		.faq-question::-webkit-details-marker {
			display: none;
		}

		.faq-question:hover {
			background: var(--p-teal-50);
		}

		.faq-chevron {
			flex-shrink: 0;
			color: var(--color-text-3);
			transition: transform var(--dur-base) var(--ease-snap);
		}

		.faq-item[open] .faq-chevron {
			transform: rotate(180deg);
		}

		.faq-answer {
			display: grid;
			grid-template-rows: 0fr;
			transition: grid-template-rows var(--dur-base) var(--ease-out);
		}

		.faq-item[open] .faq-answer {
			grid-template-rows: 1fr;
		}

		.faq-answer > p {
			overflow: hidden;
			padding: 0 var(--space-6) var(--space-4);
			font-size: var(--font-size-small);
			color: var(--color-text-2);
			line-height: 1.7;
			max-width: 60ch;
		}
	}
</style>
