---
---

<section class="editorial" aria-label="비전">
	<img
		src="/images/editorial/feature.jpg"
		alt=""
		class="editorial__bg"
		loading="lazy"
		decoding="async"
	/>
	<div class="editorial__scrim"></div>
	<div class="editorial__grain" aria-hidden="true"></div>
	<div class="editorial__content" data-reveal>
		<blockquote class="editorial__quote">
			"아직 측정되지 않은 것들을<br />눈에 보이게 만듭니다."
		</blockquote>
	</div>
</section>

<style>
	@layer components {
		.editorial {
			position: relative;
			display: flex;
			align-items: center;
			justify-content: center;
			min-height: var(--section-height-editorial);
			overflow: hidden;
		}

		.editorial__bg {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			background: var(--p-teal-100);
		}

		.editorial__scrim {
			position: absolute;
			inset: 0;
			background: var(--color-overlay-editorial);
			pointer-events: none;
		}

		.editorial__grain {
			position: absolute;
			inset: 0;
			opacity: 0.015;
			pointer-events: none;
			background-image: var(--texture-grain);
			background-repeat: repeat;
			background-size: 256px 256px;
		}

		.editorial__content {
			position: relative;
			z-index: 1;
			max-width: var(--mu-max-width);
			padding: var(--space-16) var(--mu-padding-x);
			text-align: center;
		}

		.editorial__quote {
			font-family: var(--font-display);
			font-size: var(--font-size-pullquote);
			font-weight: 500;
			color: var(--color-surface-0);
			line-height: 1.5;
			letter-spacing: -0.01em;
			text-shadow: 0 2px 16px oklch(0.1 0 0 / 0.3); /* overlay decoration — intentional */
		}

		@media (min-width: 768px) {
			.editorial__quote {
				font-size: var(--font-size-h1);
			}
		}
	}
</style>
