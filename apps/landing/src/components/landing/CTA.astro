<section class="cta-band" aria-label="시작하기">
	<div class="cta-band__inner" data-reveal>
		<h2 class="cta-band__heading">배움의 다음 장을, 함께.</h2>
		<p class="cta-band__sub">Modfolio Connect 계정으로 무료로 시작하세요</p>
		<a href="https://edu.modfolio.io" class="cta-band__btn">
			Get Started
		</a>
	</div>
</section>

<style>
	@layer components {
		.cta-band {
			min-height: 50vh;
			display: flex;
			align-items: center;
			justify-content: center;
			background: var(--p-teal-500);
			padding: var(--space-24) var(--mu-padding-x);
		}

		.cta-band__inner {
			max-width: var(--mu-max-width);
			margin: 0 auto;
			text-align: center;
		}

		.cta-band__heading {
			font-family: var(--font-display);
			font-size: var(--font-size-h1);
			font-weight: 700;
			color: var(--color-surface-0);
			line-height: 1.2;
			margin-bottom: var(--space-4);
		}

		.cta-band__sub {
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			color: var(--color-surface-0);
			opacity: 0.8;
			margin-bottom: var(--space-8);
		}

		.cta-band__btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: var(--space-3) var(--space-6);
			background: var(--color-surface-0);
			color: var(--color-interactive-primary);
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			font-weight: 600;
			border-radius: var(--radius-md);
			transition:
				transform var(--dur-fast) var(--ease-snap),
				box-shadow var(--dur-fast) var(--ease-out);
		}

		.cta-band__btn:hover {
			transform: translateY(-2px);
			box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
		}
	}
</style>
