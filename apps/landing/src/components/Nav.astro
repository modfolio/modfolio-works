---
const currentPath = Astro.url.pathname;

const navLinks = [
	{ label: "소개", href: "/about" },
	{ label: "FAQ", href: "/faq" },
];

const megamenuColumns = {
	education: {
		title: "Education",
		items: [
			{
				letter: "N",
				name: "Naviaca",
				desc: "학원 CRM + LMS",
				href: "https://naviaca.com",
				accent: "var(--color-accent-naviaca)",
				previewDesc:
					"학생 관리, 수업 편성, 출석, 성적, 결제까지 학원에 필요한 모든 기능을 하나의 시스템으로 제공합니다.",
			},
			{
				letter: "G",
				name: "GistCore",
				desc: "AI 스피킹 연습",
				href: "https://gistcore.com",
				accent: "var(--color-accent-gistcore)",
				previewDesc:
					"OPIc 실전 시나리오를 AI 튜터와 반복 연습. 발화 분석과 즉각 피드백으로 스피킹 실력을 끌어올립니다.",
			},
			{
				letter: "F",
				name: "Fortiscribe",
				desc: "AI 작문 첨삭",
				href: "https://fortiscribe.com",
				accent: "var(--color-accent-fortiscribe)",
				previewDesc:
					"영어, 한국어 작문을 제출하면 AI가 문법, 구조, 논리를 다각도로 첨삭합니다.",
			},
		],
	},
	community: {
		title: "Community",
		items: [
			{
				letter: "O",
				name: "Modfolio On",
				desc: "교육 커뮤니티",
				href: "https://on.modfolio.io",
				accent: "var(--color-interactive-primary)",
				previewDesc:
					"교육 현장의 이야기를 나누고, 교사와 학생이 함께 성장하는 커뮤니티입니다.",
			},
		],
	},
	platform: {
		title: "Platform",
		items: [
			{
				letter: "C",
				name: "Connect",
				desc: "SSO 인증",
				href: "https://connect.modfolio.io",
				accent: "var(--color-interactive-primary)",
				previewDesc:
					"한 번의 로그인으로 모든 Modfolio 앱에 접근. SSO, 패스키, 소셜 로그인을 지원합니다.",
			},
			{
				letter: "P",
				name: "Pay",
				desc: "결제 게이트웨이",
				href: "https://pay.modfolio.io",
				accent: "var(--color-interactive-primary)",
				previewDesc:
					"안전하고 투명한 결제 시스템. 학원과 학생 모두를 위한 통합 결제 게이트웨이입니다.",
			},
			{
				letter: "D",
				name: "Docs",
				desc: "문서 가이드",
				href: "https://docs.modfolio.io",
				accent: "var(--color-interactive-primary)",
				previewDesc:
					"Modfolio 생태계의 기술 문서, 가이드, API 레퍼런스를 한곳에서 확인하세요.",
			},
		],
	},
};
---

<header id="works-nav" class="nav">
	<div class="nav-inner">
		<a href="/" class="nav-logo" aria-label="Modfolio Works 홈">
			<span class="nav-logo__text">Modfolio Works</span>
		</a>

		<nav class="nav-center" aria-label="주요 탐색">
			<!-- Apps megamenu trigger -->
			<div class="mega-trigger">
				<button
					class="nav-link nav-link--apps"
					type="button"
					aria-expanded="false"
					aria-haspopup="true"
				>
					앱
					<svg class="nav-link__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
						<path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>

				<div class="mega-dropdown" role="menu">
					<div class="mega-dropdown__inner">
						<div class="mega-grid">
							<!-- Column 1: Education -->
							<div class="mega-col">
								<p class="mega-col__title">Education</p>
								{megamenuColumns.education.items.map((item, i) => (
									<a
										href={item.href}
										class="mega-item"
										style={`--i: ${i}`}
										data-preview-name={item.name}
										data-preview-desc={item.previewDesc}
										data-preview-href={item.href}
										target="_blank"
										rel="noopener noreferrer"
										role="menuitem"
									>
										<span class="mega-item__icon" style={`background: ${item.accent}`}>
											{item.letter}
										</span>
										<span class="mega-item__text">
											<span class="mega-item__name">{item.name}</span>
											<span class="mega-item__desc">{item.desc}</span>
										</span>
									</a>
								))}
							</div>

							<!-- Column 2: Community -->
							<div class="mega-col">
								<p class="mega-col__title">Community</p>
								{megamenuColumns.community.items.map((item, i) => (
									<a
										href={item.href}
										class="mega-item"
										style={`--i: ${megamenuColumns.education.items.length + i}`}
										data-preview-name={item.name}
										data-preview-desc={item.previewDesc}
										data-preview-href={item.href}
										target="_blank"
										rel="noopener noreferrer"
										role="menuitem"
									>
										<span class="mega-item__icon" style={`background: ${item.accent}`}>
											{item.letter}
										</span>
										<span class="mega-item__text">
											<span class="mega-item__name">{item.name}</span>
											<span class="mega-item__desc">{item.desc}</span>
										</span>
									</a>
								))}
							</div>

							<!-- Column 3: Platform -->
							<div class="mega-col">
								<p class="mega-col__title">Platform</p>
								{megamenuColumns.platform.items.map((item, i) => (
									<a
										href={item.href}
										class="mega-item"
										style={`--i: ${megamenuColumns.education.items.length + megamenuColumns.community.items.length + i}`}
										data-preview-name={item.name}
										data-preview-desc={item.previewDesc}
										data-preview-href={item.href}
										target="_blank"
										rel="noopener noreferrer"
										role="menuitem"
									>
										<span class="mega-item__icon" style={`background: ${item.accent}`}>
											{item.letter}
										</span>
										<span class="mega-item__text">
											<span class="mega-item__name">{item.name}</span>
											<span class="mega-item__desc">{item.desc}</span>
										</span>
									</a>
								))}
							</div>

							<!-- Column 4: Preview -->
							<div class="mega-preview" id="mega-preview">
								<p class="mega-preview__empty">앱 위에 마우스를 올려보세요</p>
								<div class="mega-preview__content" id="mega-preview-content" hidden>
									<h3 class="mega-preview__name" id="mega-preview-name"></h3>
									<p class="mega-preview__desc" id="mega-preview-desc"></p>
									<a class="mega-preview__cta" id="mega-preview-cta" href="#" target="_blank" rel="noopener noreferrer">
										방문하기
										<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
											<path d="M3.5 8h9m0 0L8.5 4m4 4l-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
										</svg>
									</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			{navLinks.map((item) => (
				<a
					href={item.href}
					class:list={[
						"nav-link",
						(currentPath === item.href || currentPath.startsWith(item.href + "/")) && "nav-link--active",
					]}
					aria-current={currentPath === item.href ? "page" : undefined}
				>
					{item.label}
				</a>
			))}
		</nav>

		<div class="nav-actions">
			<a href="https://edu.modfolio.io" class="nav-cta">시작하기</a>
			<button
				id="works-nav-toggle"
				class="nav-hamburger"
				type="button"
				aria-label="메뉴 열기"
				aria-expanded="false"
			>
				<span class="nav-hamburger__line"></span>
				<span class="nav-hamburger__line"></span>
				<span class="nav-hamburger__line"></span>
			</button>
		</div>
	</div>

	<!-- Mobile Drawer -->
	<div id="works-nav-drawer" class="nav-drawer">
		<nav class="nav-drawer__inner" aria-label="모바일 탐색">
			<!-- Education accordion -->
			<details class="nav-drawer__section">
				<summary class="nav-drawer__section-title">Education</summary>
				<div class="nav-drawer__section-items">
					{megamenuColumns.education.items.map((item) => (
						<a href={item.href} class="nav-drawer__app-link" target="_blank" rel="noopener noreferrer">
							<span class="nav-drawer__app-icon" style={`background: ${item.accent}`}>{item.letter}</span>
							<span class="nav-drawer__app-info">
								<span class="nav-drawer__app-name">{item.name}</span>
								<span class="nav-drawer__app-desc">{item.desc}</span>
							</span>
						</a>
					))}
				</div>
			</details>

			<!-- Community accordion -->
			<details class="nav-drawer__section">
				<summary class="nav-drawer__section-title">Community</summary>
				<div class="nav-drawer__section-items">
					{megamenuColumns.community.items.map((item) => (
						<a href={item.href} class="nav-drawer__app-link" target="_blank" rel="noopener noreferrer">
							<span class="nav-drawer__app-icon" style={`background: ${item.accent}`}>{item.letter}</span>
							<span class="nav-drawer__app-info">
								<span class="nav-drawer__app-name">{item.name}</span>
								<span class="nav-drawer__app-desc">{item.desc}</span>
							</span>
						</a>
					))}
				</div>
			</details>

			<!-- Platform accordion -->
			<details class="nav-drawer__section">
				<summary class="nav-drawer__section-title">Platform</summary>
				<div class="nav-drawer__section-items">
					{megamenuColumns.platform.items.map((item) => (
						<a href={item.href} class="nav-drawer__app-link" target="_blank" rel="noopener noreferrer">
							<span class="nav-drawer__app-icon" style={`background: ${item.accent}`}>{item.letter}</span>
							<span class="nav-drawer__app-info">
								<span class="nav-drawer__app-name">{item.name}</span>
								<span class="nav-drawer__app-desc">{item.desc}</span>
							</span>
						</a>
					))}
				</div>
			</details>

			<div class="nav-drawer__divider"></div>

			<a href="/about" class:list={["nav-drawer__link", currentPath === "/about" && "nav-drawer__link--active"]}>소개</a>
			<a href="/faq" class:list={["nav-drawer__link", currentPath === "/faq" && "nav-drawer__link--active"]}>FAQ</a>

			<div class="nav-drawer__divider"></div>

			<a href="https://edu.modfolio.io" class="nav-drawer__cta">시작하기</a>
		</nav>
	</div>
</header>

<script>
	const nav = document.getElementById("works-nav");
	const toggle = document.getElementById("works-nav-toggle");
	const drawer = document.getElementById("works-nav-drawer");

	if (nav && toggle && drawer) {
		let lastScrollY = 0;
		let navHidden = false;
		let drawerOpen = false;

		const show = () => {
			nav.style.transform = "translateY(0)";
			navHidden = false;
		};

		const hide = () => {
			if (drawerOpen) return;
			nav.style.transform = "translateY(-100%)";
			navHidden = true;
		};

		window.addEventListener(
			"scroll",
			() => {
				const currentY = window.scrollY;
				if (currentY > lastScrollY && currentY > 100) {
					hide();
				} else {
					show();
				}
				lastScrollY = currentY;
			},
			{ passive: true },
		);

		document.addEventListener(
			"mousemove",
			(e) => {
				if (e.clientY < 80 && navHidden) {
					show();
				}
			},
			{ passive: true },
		);

		toggle.addEventListener("click", () => {
			drawerOpen = !drawerOpen;
			if (drawerOpen) {
				drawer.style.maxHeight = `${drawer.scrollHeight}px`;
				toggle.classList.add("nav-hamburger--open");
				toggle.setAttribute("aria-expanded", "true");
				toggle.setAttribute("aria-label", "메뉴 닫기");
			} else {
				drawer.style.maxHeight = "0";
				toggle.classList.remove("nav-hamburger--open");
				toggle.setAttribute("aria-expanded", "false");
				toggle.setAttribute("aria-label", "메뉴 열기");
			}
		});
	}

	/* ── Megamenu Preview ── */
	const megaItems = document.querySelectorAll<HTMLAnchorElement>(".mega-item");
	const previewEmpty = document.querySelector<HTMLElement>(".mega-preview__empty");
	const previewContent = document.getElementById("mega-preview-content");
	const previewName = document.getElementById("mega-preview-name");
	const previewDesc = document.getElementById("mega-preview-desc");
	const previewCta = document.getElementById("mega-preview-cta") as HTMLAnchorElement | null;

	if (megaItems.length > 0 && previewEmpty && previewContent && previewName && previewDesc && previewCta) {
		const megaDropdown = document.querySelector<HTMLElement>(".mega-dropdown");

		for (const item of megaItems) {
			item.addEventListener("mouseenter", () => {
				const name = item.dataset.previewName || "";
				const desc = item.dataset.previewDesc || "";
				const href = item.dataset.previewHref || "#";

				previewName.textContent = name;
				previewDesc.textContent = desc;
				previewCta.href = href;

				previewEmpty.hidden = true;
				previewContent.hidden = false;
			});
		}

		if (megaDropdown) {
			megaDropdown.addEventListener("mouseleave", () => {
				previewEmpty.hidden = false;
				previewContent.hidden = true;
			});
		}
	}
</script>

<style>
	@layer components {
		/* ═══════════════════════════════════
		   Header Bar
		   ═══════════════════════════════════ */
		.nav {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 50;
			height: var(--nav-h);
			background: rgba(255, 255, 255, 0.9);
			backdrop-filter: blur(20px) saturate(180%);
			-webkit-backdrop-filter: blur(20px) saturate(180%);
			border-bottom: 1px solid var(--color-border-subtle);
			transition: transform 300ms var(--ease-out);
			will-change: transform;
		}

		.nav-inner {
			display: flex;
			align-items: center;
			justify-content: space-between;
			height: 100%;
			max-width: var(--mu-max-width);
			margin: 0 auto;
			padding: 0 var(--mu-padding-x);
		}

		/* ── Logo ── */
		.nav-logo {
			display: flex;
			align-items: center;
			flex-shrink: 0;
		}

		.nav-logo__text {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 700;
			color: var(--p-teal-700);
			letter-spacing: -0.01em;
		}

		/* ── Center Nav ── */
		.nav-center {
			display: none;
			align-items: center;
			gap: var(--space-8);
		}

		@media (min-width: 768px) {
			.nav-center {
				display: flex;
			}
		}

		/* ── Nav Links ── */
		.nav-link {
			position: relative;
			display: inline-flex;
			align-items: center;
			gap: 4px;
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 500;
			color: var(--color-text-2);
			padding: var(--space-1) 0;
			background: none;
			border: none;
			cursor: pointer;
			transition: color var(--dur-fast) var(--ease-out);
		}

		.nav-link::after {
			content: "";
			position: absolute;
			bottom: -2px;
			left: 0;
			right: 0;
			height: 2px;
			background: var(--color-interactive-primary);
			border-radius: var(--radius-full);
			transform: scaleX(0);
			transform-origin: center;
			transition: transform var(--dur-fast) var(--ease-out);
		}

		.nav-link:hover {
			color: var(--color-text-1);
		}

		.nav-link:hover::after {
			transform: scaleX(1);
		}

		.nav-link--active {
			color: var(--color-interactive-primary);
			font-weight: 600;
		}

		.nav-link--active::after {
			transform: scaleX(1);
		}

		.nav-link__chevron {
			transition: transform var(--dur-fast) var(--ease-out);
		}

		/* ── Actions ── */
		.nav-actions {
			display: flex;
			align-items: center;
			gap: var(--space-3);
		}

		.nav-cta {
			display: inline-flex;
			align-items: center;
			padding: var(--space-2) var(--space-4);
			background: var(--color-interactive-primary);
			color: var(--color-surface-0);
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 600;
			border-radius: var(--radius-md);
			transition:
				background var(--dur-fast) var(--ease-out),
				transform var(--dur-fast) var(--ease-out);
		}

		.nav-cta:hover {
			background: var(--color-interactive-hover);
			transform: translateY(-1px);
		}

		/* ═══════════════════════════════════
		   Hamburger (Mobile)
		   ═══════════════════════════════════ */
		.nav-hamburger {
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			gap: 5px;
			width: 36px;
			height: 36px;
			border-radius: var(--radius-sm);
			transition: background var(--dur-fast) var(--ease-out);
		}

		@media (min-width: 768px) {
			.nav-hamburger {
				display: none;
			}
		}

		.nav-hamburger:hover {
			background: var(--color-interactive-muted);
		}

		.nav-hamburger__line {
			display: block;
			width: 18px;
			height: 2px;
			background: var(--color-text-2);
			border-radius: var(--radius-full);
			transition:
				transform var(--dur-fast) var(--ease-out),
				opacity var(--dur-fast) var(--ease-out);
		}

		.nav-hamburger--open .nav-hamburger__line:nth-child(1) {
			transform: translateY(7px) rotate(45deg);
		}

		.nav-hamburger--open .nav-hamburger__line:nth-child(2) {
			opacity: 0;
		}

		.nav-hamburger--open .nav-hamburger__line:nth-child(3) {
			transform: translateY(-7px) rotate(-45deg);
		}

		/* ═══════════════════════════════════
		   Megamenu Dropdown
		   ═══════════════════════════════════ */
		.mega-trigger {
			position: relative;
		}

		.mega-dropdown {
			position: fixed;
			top: var(--nav-h);
			left: 0;
			right: 0;
			display: flex;
			justify-content: center;
			padding: var(--space-4) var(--mu-padding-x);
			pointer-events: none;
			opacity: 0;
			transform: translateY(-8px);
			transition:
				opacity 0.2s var(--ease-out),
				transform 0.2s var(--ease-out);
		}

		.mega-trigger:hover .mega-dropdown,
		.mega-trigger:focus-within .mega-dropdown {
			pointer-events: auto;
			opacity: 1;
			transform: translateY(0);
		}

		.mega-trigger:hover .nav-link__chevron,
		.mega-trigger:focus-within .nav-link__chevron {
			transform: rotate(180deg);
		}

		.mega-trigger:hover .nav-link--apps::after,
		.mega-trigger:focus-within .nav-link--apps::after {
			transform: scaleX(1);
		}

		.mega-dropdown__inner {
			width: 100%;
			max-width: var(--mu-max-width);
			background: var(--color-surface-card);
			border: 1px solid var(--color-border-subtle);
			border-radius: var(--radius-lg);
			box-shadow: var(--shadow-lg);
			padding: var(--space-8);
		}

		/* ── 4-Column Grid ── */
		.mega-grid {
			display: grid;
			grid-template-columns: 1fr 1fr 1fr 1.2fr;
			gap: var(--space-6);
		}

		@media (max-width: 1100px) {
			.mega-grid {
				grid-template-columns: 1fr 1fr 1fr;
			}

			.mega-preview {
				display: none;
			}
		}

		/* ── Column ── */
		.mega-col__title {
			font-family: var(--font-ui);
			font-size: var(--font-size-caption);
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--color-text-3);
			margin-bottom: var(--space-3);
			padding-left: var(--space-2);
		}

		/* ── Menu Item ── */
		.mega-item {
			display: flex;
			align-items: center;
			gap: var(--space-3);
			padding: var(--space-3);
			border-radius: var(--radius-md);
			text-decoration: none;
			transition: background var(--dur-fast) var(--ease-out);
			opacity: 0;
