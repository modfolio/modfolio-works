---
const currentPath = Astro.url.pathname;

const menuCategories = [
	{
		key: "education",
		title: "Education",
		items: [
			{
				letter: "N",
				name: "Naviaca",
				desc: "학원 CRM + LMS",
				href: "https://naviaca.com",
				accent: "var(--color-accent-naviaca)",
				previewDesc:
					"학생 관리, 수업 편성, 출석, 성적, 결제까지 학원에 필요한 모든 기능을 하나의 시스템으로 제공합니다.",
			},
			{
				letter: "G",
				name: "GistCore",
				desc: "AI 스피킹 연습",
				href: "https://gistcore.com",
				accent: "var(--color-accent-gistcore)",
				previewDesc:
					"OPIc 실전 시나리오를 AI 튜터와 반복 연습. 발화 분석과 즉각 피드백으로 스피킹 실력을 끌어올립니다.",
			},
			{
				letter: "F",
				name: "Fortiscribe",
				desc: "AI 작문 첨삭",
				href: "https://fortiscribe.com",
				accent: "var(--color-accent-fortiscribe)",
				previewDesc:
					"영어, 한국어 작문을 제출하면 AI가 문법, 구조, 논리를 다각도로 첨삭합니다.",
			},
		],
	},
	{
		key: "community",
		title: "Community",
		items: [
			{
				letter: "O",
				name: "Modfolio On",
				desc: "교육 커뮤니티",
				href: "https://on.modfolio.io",
				accent: "var(--color-interactive-primary)",
				previewDesc:
					"교육 현장의 이야기를 나누고, 교사와 학생이 함께 성장하는 커뮤니티입니다.",
			},
		],
	},
	{
		key: "platform",
		title: "Platform",
		items: [
			{
				letter: "C",
				name: "Connect",
				desc: "SSO 인증",
				href: "https://connect.modfolio.io",
				accent: "var(--color-interactive-primary)",
				previewDesc:
					"한 번의 로그인으로 모든 Modfolio 앱에 접근. SSO, 패스키, 소셜 로그인을 지원합니다.",
			},
			{
				letter: "P",
				name: "Pay",
				desc: "결제 게이트웨이",
				href: "https://pay.modfolio.io",
				accent: "var(--color-interactive-primary)",
				previewDesc:
					"안전하고 투명한 결제 시스템. 학원과 학생 모두를 위한 통합 결제 게이트웨이입니다.",
			},
			{
				letter: "D",
				name: "Docs",
				desc: "문서 가이드",
				href: "https://docs.modfolio.io",
				accent: "var(--color-interactive-primary)",
				previewDesc:
					"Modfolio 생태계의 기술 문서, 가이드, API 레퍼런스를 한곳에서 확인하세요.",
			},
		],
	},
];
---

<!-- Overlay -->
<div class="menu-overlay" id="menuOverlay"></div>

<!-- Mega Menu Panel -->
<div class="mega-menu" id="megaMenu">
	<div class="menu-left">
		{menuCategories.map((cat, catIdx) => (
			<div class:list={["menu-category", catIdx > 0 && "menu-category--bordered"]}>
				<p class="menu-category__title">{cat.title}</p>
				{cat.items.map((item) => (
					<a
						href={item.href}
						class="menu-item"
						data-preview-name={item.name}
						data-preview-desc={item.previewDesc}
						data-preview-url={item.href}
						target="_blank"
						rel="noopener noreferrer"
					>
						<span class="menu-item__icon" style={`background: ${item.accent}`}>
							{item.letter}
						</span>
						<span class="menu-item__text">
							<span class="menu-item__name">{item.name}</span>
							<span class="menu-item__desc">{item.desc}</span>
						</span>
					</a>
				))}
			</div>
		))}
	</div>
	<div class="menu-right">
		<div id="defaultPreview" class="menu-right__default">
			<p class="menu-right__hint">앱 위에 마우스를 올려보세요</p>
		</div>
		<div id="previewPanel" class="menu-right__panel"></div>
	</div>
</div>

<!-- Header -->
<header id="works-nav" class="nav">
	<div class="nav-inner">
		<div class="nav-left">
			<a href="/" class="nav-logo" aria-label="Modfolio Works 홈">
				<span class="nav-logo__text">Modfolio Works</span>
			</a>

			<nav class="nav-center" aria-label="주요 탐색">
				<button
					id="menuTrigger"
					class:list={[
						"nav-link",
						"nav-link--apps",
						(currentPath === "/apps" || currentPath.startsWith("/apps/")) && "nav-link--active",
					]}
					type="button"
					aria-expanded="false"
					aria-haspopup="true"
				>
					Apps
					<svg class="nav-link__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
						<path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>

				<a
					href="/contact"
					class:list={[
						"nav-link",
						(currentPath === "/contact" || currentPath.startsWith("/contact/")) && "nav-link--active",
					]}
					aria-current={currentPath === "/contact" ? "page" : undefined}
				>
					Contact
				</a>
			</nav>
		</div>

		<div class="nav-actions">
			<a href="https://edu.modfolio.io" class="nav-cta">Get Started</a>
			<button
				id="works-nav-toggle"
				class="nav-hamburger"
				type="button"
				aria-label="메뉴 열기"
				aria-expanded="false"
			>
				<span class="nav-hamburger__line"></span>
				<span class="nav-hamburger__line"></span>
				<span class="nav-hamburger__line"></span>
			</button>
		</div>
	</div>

	<!-- Mobile Drawer -->
	<div id="works-nav-drawer" class="nav-drawer">
		<nav class="nav-drawer__inner" aria-label="모바일 탐색">
			{menuCategories.map((cat) => (
				<details class="nav-drawer__section">
					<summary class="nav-drawer__section-title">{cat.title}</summary>
					<div class="nav-drawer__section-items">
						{cat.items.map((item) => (
							<a href={item.href} class="nav-drawer__app-link" target="_blank" rel="noopener noreferrer">
								<span class="nav-drawer__app-icon" style={`background: ${item.accent}`}>{item.letter}</span>
								<span class="nav-drawer__app-info">
									<span class="nav-drawer__app-name">{item.name}</span>
									<span class="nav-drawer__app-desc">{item.desc}</span>
								</span>
							</a>
						))}
					</div>
				</details>
			))}

			<div class="nav-drawer__divider"></div>

			<a
				href="/contact"
				class:list={[
					"nav-drawer__link",
					(currentPath === "/contact" || currentPath.startsWith("/contact/")) && "nav-drawer__link--active",
				]}
				aria-current={currentPath === "/contact" ? "page" : undefined}
			>
				Contact
			</a>

			<div class="nav-drawer__divider"></div>

			<a href="https://edu.modfolio.io" class="nav-drawer__cta">Get Started</a>
		</nav>
	</div>
</header>

<script>
	/* ═══════════════════════════════════
	   Scroll Hide / Show
	   ═══════════════════════════════════ */
	const nav = document.getElementById("works-nav");
	const toggle = document.getElementById("works-nav-toggle");
	const drawer = document.getElementById("works-nav-drawer");

	if (nav && toggle && drawer) {
		let lastScrollY = 0;
		let navHidden = false;
		let drawerOpen = false;

		const showNav = () => {
			nav.style.transform = "translateY(0)";
			navHidden = false;
		};

		const hideNav = () => {
			if (drawerOpen) return;
			if (megaMenu?.classList.contains("active")) return;
			nav.style.transform = "translateY(-100%)";
			navHidden = true;
		};

		window.addEventListener(
			"scroll",
			() => {
				const currentY = window.scrollY;
				if (currentY > lastScrollY && currentY > 100) {
					hideNav();
				} else {
					showNav();
				}
				lastScrollY = currentY;
			},
			{ passive: true },
		);

		document.addEventListener(
			"mousemove",
			(e) => {
				if (e.clientY < 80 && navHidden) {
					showNav();
				}
			},
			{ passive: true },
		);

		toggle.addEventListener("click", () => {
			drawerOpen = !drawerOpen;
			if (drawerOpen) {
				drawer.style.maxHeight = `${drawer.scrollHeight}px`;
				toggle.classList.add("nav-hamburger--open");
				toggle.setAttribute("aria-expanded", "true");
				toggle.setAttribute("aria-label", "메뉴 닫기");
			} else {
				drawer.style.maxHeight = "0";
				toggle.classList.remove("nav-hamburger--open");
				toggle.setAttribute("aria-expanded", "false");
				toggle.setAttribute("aria-label", "메뉴 열기");
			}
		});
	}

	/* ═══════════════════════════════════
	   Mega Menu — Open / Close
	   ═══════════════════════════════════ */
	const menuTrigger = document.getElementById("menuTrigger");
	const overlay = document.getElementById("menuOverlay");
	const megaMenu = document.getElementById("megaMenu");

	function openMenu() {
		overlay?.classList.add("active");
		megaMenu?.classList.add("active");
		menuTrigger?.setAttribute("aria-expanded", "true");
		menuTrigger?.classList.add("nav-link--menu-open");
	}

	function closeMenu() {
		overlay?.classList.remove("active");
		megaMenu?.classList.remove("active");
		menuTrigger?.setAttribute("aria-expanded", "false");
		menuTrigger?.classList.remove("nav-link--menu-open");
	}

	menuTrigger?.addEventListener("click", () => {
		const isOpen = megaMenu?.classList.contains("active");
		if (isOpen) {
			closeMenu();
		} else {
			openMenu();
		}
	});

	overlay?.addEventListener("click", closeMenu);

	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") closeMenu();
	});

	window.addEventListener("scroll", closeMenu, { passive: true });

	/* ═══════════════════════════════════
	   Preview Panel — Hover
	   ═══════════════════════════════════ */
	const menuItems = document.querySelectorAll<HTMLElement>("[data-preview-name]");
	const previewPanel = document.getElementById("previewPanel");
	const defaultPreview = document.getElementById("defaultPreview");

	for (const item of menuItems) {
		item.addEventListener("mouseenter", () => {
			const name = item.dataset.previewName;
			const desc = item.dataset.previewDesc;
			const url = item.dataset.previewUrl;
			if (previewPanel && defaultPreview) {
				defaultPreview.style.display = "none";
				previewPanel.innerHTML = `
					<h3 class="preview-name">${name}</h3>
					<p class="preview-desc">${desc}</p>
					<a href="${url}" class="preview-link" target="_blank" rel="noopener noreferrer">방문하기 →</a>
				`;
			}
		});
	}

	document.querySelector(".menu-left")?.addEventListener("mouseleave", () => {
		if (previewPanel && defaultPreview) {
			previewPanel.innerHTML = "";
			defaultPreview.style.display = "block";
		}
	});
</script>

<style>
	@layer components {
		/* ═══════════════════════════════════
		   Overlay
		   ═══════════════════════════════════ */
		.menu-overlay {
			position: fixed;
			inset: 0;
			top: var(--nav-h);
			background: rgba(0, 0, 0, 0.3);
			backdrop-filter: blur(2px);
			z-index: 90;
			opacity: 0;
			visibility: hidden;
			transition: opacity 0.25s ease, visibility 0.25s ease;
		}

		.menu-overlay.active {
			opacity: 1;
			visibility: visible;
		}

		/* ═══════════════════════════════════
		   Mega Menu Panel
		   ═══════════════════════════════════ */
		.mega-menu {
			position: fixed;
			top: var(--nav-h);
			left: 0;
			bottom: 0;
			background: var(--color-surface-0);
			z-index: 95;
			display: grid;
			grid-template-columns: 420px 1fr;
			width: 100%;
			max-width: 1000px;
			box-shadow: 4px 0 30px rgba(0, 0, 0, 0.12);
			opacity: 0;
			visibility: hidden;
			transition: opacity 0.25s ease, visibility 0.25s ease;
			overflow: hidden;
		}

		.mega-menu.active {
			opacity: 1;
			visibility: visible;
		}

		/* ── Staggered Column Fade-In ── */
		.menu-left {
			opacity: 0;
			transform: translateY(8px);
			transition: opacity 0.35s ease, transform 0.35s ease;
			padding: var(--space-6) var(--space-8);
			border-right: 1px solid var(--color-border-subtle);
			overflow-y: auto;
		}

		.menu-right {
			opacity: 0;
			transform: translateY(8px);
			transition: opacity 0.35s ease 0.12s, transform 0.35s ease 0.12s;
			background: var(--p-teal-50);
			padding: var(--space-10);
			display: flex;
			flex-direction: column;
			justify-content: center;
		}

		.mega-menu.active .menu-left,
		.mega-menu.active .menu-right {
			opacity: 1;
			transform: translateY(0);
		}

		/* ── Left Column: Categories ── */
		.menu-category {
			padding-bottom: var(--space-4);
		}

		.menu-category--bordered {
			border-top: 1px solid var(--color-border-subtle);
			padding-top: var(--space-4);
		}

		.menu-category__title {
			font-family: var(--font-ui);
			font-size: var(--font-size-caption);
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--color-text-3);
			margin-bottom: var(--space-3);
		}

		/* ── Menu Items ── */
		.menu-item {
			display: flex;
			align-items: center;
			gap: var(--space-3);
			padding: var(--space-2);
			border-radius: var(--radius-md);
			text-decoration: none;
			transition: background var(--dur-fast) var(--ease-out);
		}

		.menu-item:hover {
			background: var(--p-teal-50);
		}

		.menu-item__icon {
			display: grid;
			place-items: center;
			width: 32px;
			height: 32px;
			border-radius: var(--radius-full);
			font-family: var(--font-display);
			font-size: var(--font-size-small);
			font-weight: 700;
			color: var(--color-surface-0);
			flex-shrink: 0;
			line-height: 1;
		}

		.menu-item__text {
			display: flex;
			flex-direction: column;
			gap: 2px;
			min-width: 0;
		}

		.menu-item__name {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 500;
			color: var(--color-text-1);
		}

		.menu-item__desc {
			font-family: var(--font-ui);
			font-size: var(--font-size-caption);
			color: var(--color-text-3);
		}

		/* ── Right Column: Preview ── */
		.menu-right__default {
			display: flex;
			align-items: center;
			justify-content: center;
			height: 100%;
		}

		.menu-right__hint {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			color: var(--color-text-3);
			font-style: italic;
		}

		.menu-right__panel {
			display: flex;
			flex-direction: column;
			gap: var(--space-4);
		}

		/* Preview Panel Dynamic Content */
		:global(.preview-name) {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 500;
			color: var(--color-text-1);
		}

		:global(.preview-desc) {
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			color: var(--color-text-2);
			line-height: 1.7;
		}

		:global(.preview-link) {
			display: inline-flex;
			align-items: center;
			gap: var(--space-2);
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 600;
			color: var(--color-interactive-primary);
			margin-top: var(--space-2);
			transition: gap var(--dur-fast) var(--ease-out);
		}

		:global(.preview-link:hover) {
			gap: var(--space-3);
		}

		/* ═══════════════════════════════════
		   Header Bar
		   ═══════════════════════════════════ */
		.nav {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 50;
			height: var(--nav-h);
			background: rgba(255, 255, 255, 0.7);
			backdrop-filter: blur(20px) saturate(180%);
			-webkit-backdrop-filter: blur(20px) saturate(180%);
			border-bottom: 1px solid var(--color-border-subtle);
			transition: transform 300ms var(--ease-out);
			will-change: transform;
		}

		.nav-inner {
			display: flex;
			align-items: center;
			height: 100%;
			padding: 0 var(--mu-padding-x);
		}

		/* ── Logo + Nav Group (left side) ── */
		.nav-left {
			display: flex;
			align-items: center;
			gap: var(--space-8);
		}

		.nav-logo {
			display: flex;
			align-items: center;
			flex-shrink: 0;
		}

		.nav-logo__text {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 700;
			color: var(--p-teal-700);
			letter-spacing: -0.01em;
		}

		/* ── Center Nav ── */
		.nav-center {
			display: none;
			align-items: center;
			gap: var(--space-8);
		}

		@media (min-width: 768px) {
			.nav-center {
				display: flex;
			}
		}

		/* ── Nav Links ── */
		.nav-link {
			position: relative;
			display: inline-flex;
			align-items: center;
			gap: 4px;
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 500;
			color: var(--color-text-2);
			padding: var(--space-1) 0;
			background: none;
			border: none;
			cursor: pointer;
			transition: color var(--dur-fast) var(--ease-out);
		}

		.nav-link::after {
			content: "";
			position: absolute;
			bottom: -2px;
			left: 0;
			right: 0;
			height: 2px;
			background: var(--color-interactive-primary);
			border-radius: var(--radius-full);
			transform: scaleX(0);
			transform-origin: center;
			transition: transform var(--dur-fast) var(--ease-out);
		}

		.nav-link:hover {
			color: var(--color-text-1);
		}

		.nav-link:hover::after {
			transform: scaleX(1);
		}

		.nav-link--active {
			color: var(--color-interactive-primary);
			font-weight: 600;
		}

		.nav-link--active::after {
			transform: scaleX(1);
		}

		.nav-link--menu-open {
			color: var(--color-text-1);
		}

		.nav-link--menu-open::after {
			transform: scaleX(1);
		}

		.nav-link--menu-open .nav-link__chevron {
			transform: rotate(180deg);
		}

		.nav-link__chevron {
			transition: transform var(--dur-fast) var(--ease-out);
		}

		/* ── Actions (push to right edge) ── */
		.nav-actions {
			display: flex;
			align-items: center;
			gap: var(--space-3);
			margin-left: auto;
		}

		.nav-cta {
			display: inline-flex;
			align-items: center;
			padding: var(--space-2) var(--space-4);
			background: var(--color-interactive-primary);
			color: var(--color-surface-0);
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 600;
			border-radius: var(--radius-md);
			transition:
				background var(--dur-fast) var(--ease-out),
				transform var(--dur-fast) var(--ease-out);
		}

		.nav-cta:hover {
			background: var(--color-interactive-hover);
			transform: translateY(-1px);
		}

		/* ═══════════════════════════════════
		   Hamburger (Mobile)
		   ═══════════════════════════════════ */
		.nav-hamburger {
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			gap: 5px;
			width: 36px;
			height: 36px;
			background: none;
			border: none;
			cursor: pointer;
			border-radius: var(--radius-sm);
			transition: background var(--dur-fast) var(--ease-out);
		}

		@media (min-width: 768px) {
			.nav-hamburger {
				display: none;
			}
		}

		.nav-hamburger:hover {
			background: var(--color-interactive-muted);
		}

		.nav-hamburger__line {
			display: block;
			width: 18px;
			height: 2px;
			background: var(--color-text-2);
			border-radius: var(--radius-full);
			transition:
