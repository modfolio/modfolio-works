---
const currentPath = Astro.url.pathname;
---

<!-- Header -->
<header id="works-nav" class="nav">
	<div class="nav-inner">
		<div class="nav-left">
			<a href="/" class="nav-logo" aria-label="Modfolio Works 홈">
				<span class="nav-logo__text">Modfolio Works</span>
			</a>

			<nav class="nav-center" aria-label="주요 탐색">
				<a
					href="/apps"
					class:list={[
						"nav-link",
						(currentPath === "/apps" || currentPath.startsWith("/apps/")) && "nav-link--active",
					]}
					aria-current={currentPath === "/apps" ? "page" : undefined}
				>
					Apps
				</a>
				<a
					href="/contact"
					class:list={[
						"nav-link",
						(currentPath === "/contact" || currentPath.startsWith("/contact/")) && "nav-link--active",
					]}
					aria-current={currentPath === "/contact" ? "page" : undefined}
				>
					Contact
				</a>
			</nav>
		</div>

		<div class="nav-actions">
			<a href="https://edu.modfolio.io" class="nav-cta">Get Started</a>
			<button
				id="works-nav-toggle"
				class="nav-hamburger"
				type="button"
				aria-label="메뉴 열기"
				aria-expanded="false"
			>
				<span class="nav-hamburger__line"></span>
				<span class="nav-hamburger__line"></span>
				<span class="nav-hamburger__line"></span>
			</button>
		</div>
	</div>

	<!-- Mobile Drawer -->
	<div id="works-nav-drawer" class="nav-drawer">
		<a
			href="/apps"
			class:list={[
				"nav-drawer__link",
				(currentPath === "/apps" || currentPath.startsWith("/apps/")) && "nav-drawer__link--active",
			]}
			aria-current={currentPath === "/apps" ? "page" : undefined}
		>
			Apps
		</a>
		<a
			href="/contact"
			class:list={[
				"nav-drawer__link",
				(currentPath === "/contact" || currentPath.startsWith("/contact/")) && "nav-drawer__link--active",
			]}
			aria-current={currentPath === "/contact" ? "page" : undefined}
		>
			Contact
		</a>
		<hr class="nav-drawer__divider" />
		<a href="https://edu.modfolio.io" class="nav-drawer__cta">Get Started</a>
	</div>
</header>

<script>
	/* ═══════════════════════════════════
	   Scroll Hide / Show
	   ═══════════════════════════════════ */
	const nav = document.getElementById("works-nav");
	const toggle = document.getElementById("works-nav-toggle");
	const drawer = document.getElementById("works-nav-drawer");

	if (nav && toggle && drawer) {
		let lastScrollY = 0;
		let navHidden = false;
		let drawerOpen = false;

		const showNav = () => {
			nav.style.transform = "translateY(0)";
			navHidden = false;
		};

		const hideNav = () => {
			if (drawerOpen) return;
			nav.style.transform = "translateY(-100%)";
			navHidden = true;
		};

		window.addEventListener(
			"scroll",
			() => {
				const currentY = window.scrollY;
				if (currentY > lastScrollY && currentY > 100) {
					hideNav();
				} else {
					showNav();
				}
				lastScrollY = currentY;
			},
			{ passive: true },
		);

		document.addEventListener(
			"mousemove",
			(e) => {
				if (e.clientY < 80 && navHidden) {
					showNav();
				}
			},
			{ passive: true },
		);

		toggle.addEventListener("click", () => {
			drawerOpen = !drawerOpen;
			if (drawerOpen) {
				drawer.style.maxHeight = `${drawer.scrollHeight}px`;
				toggle.classList.add("nav-hamburger--open");
				toggle.setAttribute("aria-expanded", "true");
				toggle.setAttribute("aria-label", "메뉴 닫기");
			} else {
				drawer.style.maxHeight = "0";
				toggle.classList.remove("nav-hamburger--open");
				toggle.setAttribute("aria-expanded", "false");
				toggle.setAttribute("aria-label", "메뉴 열기");
			}
		});
	}
</script>

<style>
	@layer components {
		/* ═══════════════════════════════════
		   Header Bar
		   ═══════════════════════════════════ */
		.nav {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 50;
			height: var(--nav-h);
			background: rgba(255, 255, 255, 0.7);
			backdrop-filter: blur(20px) saturate(180%);
			-webkit-backdrop-filter: blur(20px) saturate(180%);
			border-bottom: 1px solid var(--color-border-subtle);
			transition: transform 300ms var(--ease-out);
			will-change: transform;
		}

		.nav-inner {
			display: flex;
			align-items: center;
			height: 100%;
			padding: 0 var(--mu-padding-x);
		}

		/* ── Logo + Nav Group (left side) ── */
		.nav-left {
			display: flex;
			align-items: center;
			gap: var(--space-8);
		}

		.nav-logo {
			display: flex;
			align-items: center;
			flex-shrink: 0;
		}

		.nav-logo__text {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 700;
			color: var(--p-teal-700);
			letter-spacing: -0.01em;
		}

		/* ── Center Nav ── */
		.nav-center {
			display: none;
			align-items: center;
			gap: var(--space-8);
		}

		@media (min-width: 768px) {
			.nav-center {
				display: flex;
			}
		}

		/* ── Nav Links ── */
		.nav-link {
			position: relative;
			display: inline-flex;
			align-items: center;
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 500;
			color: var(--color-text-2);
			padding: var(--space-1) 0;
			transition: color var(--dur-fast) var(--ease-out);
		}

		.nav-link::after {
			content: "";
			position: absolute;
			bottom: -2px;
			left: 0;
			right: 0;
			height: 2px;
			background: var(--color-interactive-primary);
			border-radius: var(--radius-full);
			transform: scaleX(0);
			transform-origin: center;
			transition: transform var(--dur-fast) var(--ease-out);
		}

		.nav-link:hover {
			color: var(--color-text-1);
		}

		.nav-link:hover::after {
			transform: scaleX(1);
		}

		.nav-link--active {
			color: var(--color-interactive-primary);
			font-weight: 600;
		}

		.nav-link--active::after {
			transform: scaleX(1);
		}

		/* ── Actions (push to right edge) ── */
		.nav-actions {
			display: flex;
			align-items: center;
			gap: var(--space-3);
			margin-left: auto;
		}

		.nav-cta {
			display: inline-flex;
			align-items: center;
			padding: var(--space-2) var(--space-4);
			background: var(--color-interactive-primary);
			color: var(--color-surface-0);
			font-family: var(--font-ui);
			font-size: var(--font-size-small);
			font-weight: 600;
			border-radius: var(--radius-md);
			transition:
				background var(--dur-fast) var(--ease-out),
				transform var(--dur-fast) var(--ease-out);
		}

		.nav-cta:hover {
			background: var(--color-interactive-hover);
			transform: translateY(-1px);
		}

		/* ═══════════════════════════════════
		   Hamburger (Mobile)
		   ═══════════════════════════════════ */
		.nav-hamburger {
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			gap: 5px;
			width: 36px;
			height: 36px;
			background: none;
			border: none;
			cursor: pointer;
			border-radius: var(--radius-sm);
			transition: background var(--dur-fast) var(--ease-out);
		}

		@media (min-width: 768px) {
			.nav-hamburger {
				display: none;
			}
		}

		.nav-hamburger:hover {
			background: var(--color-interactive-muted);
		}

		.nav-hamburger__line {
			display: block;
			width: 18px;
			height: 2px;
			background: var(--color-text-2);
			border-radius: var(--radius-full);
			transition:
				transform var(--dur-fast) var(--ease-out),
				opacity var(--dur-fast) var(--ease-out);
		}

		.nav-hamburger--open .nav-hamburger__line:nth-child(1) {
			transform: translateY(7px) rotate(45deg);
		}

		.nav-hamburger--open .nav-hamburger__line:nth-child(2) {
			opacity: 0;
		}

		.nav-hamburger--open .nav-hamburger__line:nth-child(3) {
			transform: translateY(-7px) rotate(-45deg);
		}

		/* ═══════════════════════════════════
		   Mobile Drawer
		   ═══════════════════════════════════ */
		.nav-drawer {
			display: block;
			overflow: hidden;
			max-height: 0;
			background: rgba(255, 255, 255, 0.95);
			backdrop-filter: blur(20px) saturate(180%);
			-webkit-backdrop-filter: blur(20px) saturate(180%);
			border-top: 1px solid var(--color-border-subtle);
			transition: max-height 300ms var(--ease-out);
			will-change: max-height;
			padding: 0 var(--mu-padding-x);
		}

		@media (min-width: 768px) {
			.nav-drawer {
				display: none;
			}
		}

		.nav-drawer__link {
			display: block;
			padding: var(--space-3);
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			font-weight: 500;
			color: var(--color-text-2);
			border-radius: var(--radius-md);
			transition: all var(--dur-fast) var(--ease-out);
			margin-top: var(--space-2);
		}

		.nav-drawer__link:first-child {
			margin-top: var(--space-4);
		}

		.nav-drawer__link:hover {
			color: var(--color-text-1);
			background: var(--color-interactive-muted);
		}

		.nav-drawer__link--active {
			color: var(--color-interactive-primary);
			font-weight: 600;
			background: var(--color-interactive-muted);
		}

		.nav-drawer__divider {
			height: 1px;
			border: none;
			background: var(--color-border-subtle);
			margin: var(--space-2) 0;
		}

		.nav-drawer__cta {
			display: flex;
			align-items: center;
			justify-content: center;
			padding: var(--space-3) var(--space-4);
			margin-bottom: var(--space-4);
			background: var(--color-interactive-primary);
			color: var(--color-surface-0);
			font-family: var(--font-ui);
			font-size: var(--font-size-body);
			font-weight: 600;
			border-radius: var(--radius-md);
			transition:
				background var(--dur-fast) var(--ease-out),
				transform var(--dur-fast) var(--ease-out);
		}

		.nav-drawer__cta:hover {
			background: var(--color-interactive-hover);
		}
	}
</style>
