---
import type { WorksApp } from "../../lib/apps";

interface Props {
	app: WorksApp;
}

const { app } = Astro.props;
const isActive = app.status === "active";
const monogram = app.name.charAt(0);
---

<article class:list={["app-card", { "app-card--active": isActive }]}>
	<div class="app-card__strip" style={`background: ${app.accentVar}`}></div>
	<div class="app-card__content">
		<div class="app-card__top">
			<div class="app-card__icon" style={`color: ${app.accentVar}`} aria-hidden="true">
				{monogram}
			</div>
			<div>
				<h2 class="app-card__name">{app.name}</h2>
				<span class="app-card__domain">{app.domain}</span>
			</div>
		</div>
		<p class="app-card__tagline">{app.tagline}</p>
		<p class="app-card__desc">{app.description}</p>
		<div class="app-card__footer">
			<span class:list={[
				"app-card__status",
				isActive ? "app-card__status--active" : "app-card__status--landing"
			]}>
				{isActive ? "Active" : "Coming Soon"}
			</span>
			{isActive ? (
				<a href={app.url} class="app-card__action" target="_blank" rel="noopener">
					앱 열기
					<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
						<path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</a>
			) : (
				<span class="app-card__action app-card__action--disabled">준비 중</span>
			)}
		</div>
	</div>
</article>

<style>
	@layer components {
		.app-card {
			display: flex;
			background: var(--color-surface-card);
			border: 1px solid var(--color-border-default);
			border-radius: var(--radius-lg);
			overflow: hidden;
			transition:
				transform var(--dur-base) var(--ease-out),
				border-color var(--dur-fast) var(--ease-out),
				box-shadow var(--dur-fast) var(--ease-out);
		}

		.app-card--active:hover {
			transform: translateY(-2px);
			border-color: var(--color-border-hover);
			box-shadow: var(--shadow-md);
		}

		.app-card:not(.app-card--active):hover {
			border-color: var(--color-border-hover);
		}

		.app-card__strip {
			flex-shrink: 0;
			width: 4px;
		}

		.app-card__content {
			flex: 1;
			padding: var(--space-6);
			display: flex;
			flex-direction: column;
		}

		.app-card__top {
			display: flex;
			align-items: center;
			gap: var(--space-3);
			margin-bottom: var(--space-4);
		}

		.app-card__icon {
			display: flex;
			align-items: center;
			justify-content: center;
			width: 40px;
			height: 40px;
			border-radius: var(--radius-md);
			background: oklch(0.20 0.01 275);
			font-family: var(--font-display);
			font-size: 1.25rem;
			font-weight: 700;
			flex-shrink: 0;
		}

		.app-card__name {
			font-family: var(--font-display);
			font-size: var(--font-size-h3);
			font-weight: 700;
			color: var(--color-text-1);
			line-height: 1.2;
		}

		.app-card__domain {
			font-size: var(--font-size-caption);
			color: var(--color-text-3);
		}

		.app-card__tagline {
			font-size: var(--font-size-body);
			font-weight: 500;
			color: var(--color-text-1);
			margin-bottom: var(--space-2);
		}

		.app-card__desc {
			font-size: var(--font-size-small);
			color: var(--color-text-2);
			line-height: 1.65;
			max-width: 50ch;
			margin-bottom: var(--space-6);
			flex: 1;
		}

		.app-card__footer {
			display: flex;
			align-items: center;
			justify-content: space-between;
		}

		.app-card__status {
			font-size: var(--font-size-caption);
			font-family: var(--font-ui);
			text-transform: uppercase;
			letter-spacing: 0.05em;
			padding: var(--space-1) var(--space-3);
			border-radius: var(--radius-full);
		}

		.app-card__status--active {
			background: oklch(0.72 0.12 155 / 0.12);
			color: var(--color-success);
		}

		.app-card__status--landing {
			background: oklch(0.80 0.08 65 / 0.12);
			color: var(--color-accent-fortiscribe);
		}

		.app-card__action {
			display: inline-flex;
			align-items: center;
			gap: var(--space-2);
			font-size: var(--font-size-small);
			font-weight: 600;
			color: var(--color-text-1);
			transition: color var(--dur-fast) var(--ease-out);
		}

		.app-card__action:hover {
			color: var(--color-interactive-primary);
		}

		.app-card__action--disabled {
			color: var(--color-text-3);
			cursor: default;
		}

		.app-card__action--disabled:hover {
			color: var(--color-text-3);
		}
	}
</style>
