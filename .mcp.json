{
	"mcpServers": {
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
				"Authorization": "Bearer ${GITHUB_TOKEN}"
			}
		},
		"playwright": {
			"type": "stdio",
			"command": "bunx",
			"args": ["--bun", "-y", "@anthropic-ai/mcp-playwright"]
		},
		"astro": {
			"type": "http",
			"url": "https://mcp.docs.astro.build/mcp"
		}
	}
}
